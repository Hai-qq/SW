@font-face {
  font-family: 'Material Symbols Outlined';
  font-style: normal;
  src: url("https://fonts.gstatic.com/s/materialsymbolsoutlined/v173/kJF1BvYX7BgnkSrUwT8OhrdQw4oELdPIeeII9v6oDMzByHX9rA6RzaxHMPdY43zj-jCxv3fzvRNU22ZXGJpEpjC_1n-q_4MrImHCIJIZrDCvHOej.woff2") format('woff2');
}

.material-symbols-outlined {
  font-family: 'Material Symbols Outlined' !important;
  font-weight: normal;
  font-style: normal;
  display: inline-block;
  white-space: nowrap;
  word-wrap: normal;
  direction: ltr;
  -webkit-font-feature-settings: 'liga';
  -webkit-font-smoothing: antialiased;
  
  /* CRITICAL FIX: 防止字体未加载前，长串连写文字撑爆 Flex 布局 */
  max-width: 1em;
  overflow: hidden;
  text-align: center;
  vertical-align: bottom;
}
