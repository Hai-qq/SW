<!--pages/home/home.wxml-->
<view class="container" style="min-height: {{windowHeight}}px;">
  <!-- 最底层背景: 极简奶油色渐变 -->
  <view class="bg-gradient"></view>

  <!-- 顶部导航区 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-content" style="margin-top: {{headerContentMT}}px; height: {{menuTriggerH}}px;">
      <!-- 我的档案胶囊按钮 -->
      <view class="profile-capsule-btn" bindtap="goToProfile">
        <text class="profile-capsule-text">我的档案</text>
        <text class="profile-capsule-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 心理学测试入口: fixed 定位，位于菜单按钮左侧 -->
  <view
    class="psych-test-trigger"
    style="right: calc({{menuTriggerRight}}px + 96rpx); top: {{menuTriggerTop}}px; height: {{menuTriggerH}}px;"
    bindtap="openPsychTest">
    <text class="psych-test-icon">✦</text>
    <text class="psych-test-label">测一测</text>
  </view>

  <!-- 功能菜单按钮: fixed 定位，紧贴胶囊左侧（沙漏图标） -->
  <view
    class="menu-trigger"
    style="right: {{menuTriggerRight}}px; top: {{menuTriggerTop}}px; height: {{menuTriggerH}}px;"
    bindtap="toggleMenuPanel">
    <image src="/assets/icons/hourglass.svg" class="menu-hourglass-svg" mode="aspectFit"></image>
  </view>

  <!-- 菜单面板遮罩 -->
  <view class="menu-mask" wx:if="{{showMenuPanel}}" catchtap="closeMenuPanel"></view>

  <!-- 菜单面板：匹配筛选 -->
  <view class="menu-panel" wx:if="{{showMenuPanel}}" style="top: calc({{statusBarHeight}}px + 88rpx);">
    <text class="menu-panel-label">匹配筛选</text>

    <!-- 城市（多选） -->
    <view class="filter-group">
      <text class="filter-group-title">城市</text>
      <view class="filter-chips">
        <view
          wx:for="{{cityOptions}}"
          wx:key="index"
          class="filter-chip {{matchFilter.city.indexOf(item) !== -1 ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="toggleCityFilter">
          <text class="filter-chip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 性别（单选） -->
    <view class="filter-group">
      <text class="filter-group-title">性别</text>
      <view class="filter-chips">
        <view
          wx:for="{{genderOptions}}"
          wx:key="index"
          class="filter-chip {{matchFilter.gender === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="toggleGenderFilter">
          <text class="filter-chip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 年龄段（单选） -->
    <view class="filter-group">
      <text class="filter-group-title">年龄段</text>
      <view class="filter-chips">
        <view
          wx:for="{{ageRangeOptions}}"
          wx:key="index"
          class="filter-chip {{matchFilter.ageRange === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="toggleAgeFilter">
          <text class="filter-chip-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <scroll-view scroll-y="true" enable-flex class="main-content">

    <!-- 顶部横向好友墙/同频人列表 -->
    <scroll-view scroll-x="true" class="stories-list" show-scrollbar="false">
      <!-- 个人入口 -->
      <view class="story-item">
        <view class="avatar-wrap you-wrap">
          <image class="avatar-img" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBKIsQ_bqFzmWxDSDkiZxPO2wAgWkowGYIPO4QTcuJtrO_sZjy0vXIEH1v_IzEUuvE_MstRGn0ENMLnF5L2ZeoRnB0UdWrIdPqBSjYMPZxI9YbWyRNotG8jewPQeF_UXwfxGe52oL8DVzjv6kx3-eOQ7g8BR28FK-whVhDgDX6Yw9c9intyLOHfgDXnjdwJF8aOtUZ9TSTQg3E4UuDDbI4utTxXxxtUjdgDmFuZzO3eQznb6Wxt0K_uYOa2MWd63rKUaVmx58SBfww" mode="aspectFill"></image>
          <view class="badge black-badge"></view>
        </view>
        <text class="name-text">你</text>
      </view>
      <!-- 推荐匹配者 -->
      <view class="story-item" wx:for="{{recommendUsers}}" wx:key="id">
        <view class="avatar-wrap">
          <image class="avatar-img" src="{{item.avatar}}" mode="aspectFill"></image>
          <view class="badge"></view>
        </view>
        <text class="name-text">{{item.name}}</text>
      </view>
    </scroll-view>

    <!-- 核心卡片容器 -->
    <view class="card-wrapper {{isCardMoving || isCardExiting ? 'is-clearing' : ''}}">
      <view class="card-stack-layer back-one"></view>
      <view class="card-stack-layer back-two"></view>
      <view class="card-preview {{isCardExiting ? 'is-exiting' : ''}}" style="transform: translateY(30rpx) scale({{previewScale}});">
        <view class="card-preview-body"></view>
      </view>
      <view
        class="card-inner"
        style="transform: translateX({{cardTranslateX}}px) translateY({{cardTranslateY}}px) rotate({{cardRotate}}deg); transition: {{cardTransition}}; opacity: {{cardOpacity}};"
        catchtouchstart="touchStart"
        catchtouchmove="touchMove"
        catchtouchend="touchEnd">

        <!-- 卡片顶部: 分享(左) + 减少推荐(右) -->
        <view class="card-top-row">
          <view class="share-trigger" bindtap="handleShare">
            <text class="share-trigger-icon">↗</text>
          </view>
          <view
            class="reduce-trigger"
            catchtouchstart="stopCardTouch"
            catchtouchmove="stopCardTouch"
            catchtouchend="reduceSimilarTopics">
            <text class="reduce-trigger-icon">×</text>
          </view>
        </view>

        <!-- 卡片正文: 观点题干 -->
        <view class="card-body">
          <text class="opinion-text">"{{currentCard.content}}"</text>
        </view>

        <!-- 卡片选项: 左认同 / 右不认同（高度约占卡片1/4） -->
        <view class="card-options">
          <view class="card-option-left" bindtap="forceSwipeRight">
            <text class="option-arrow-left">←</text>
            <text class="option-label-text agree-text">认同</text>
          </view>
          <view class="card-option-divider"></view>
          <view class="card-option-right" bindtap="forceSwipeLeft">
            <text class="option-label-text disagree-text">不认同</text>
            <text class="option-arrow-right">→</text>
          </view>
        </view>

        <!-- 卡片底部: 进度条 + 通栏评论入口 -->
        <view class="card-footer">
          <!-- 通栏评论入口 -->
          <view class="comment-bar" bindtap="openCommentPanel">
            <view class="comment-bar-icon-wrap">
              <image src="/assets/icons/forum.svg" class="comment-bar-icon" mode="aspectFit"></image>
            </view>
            <text class="comment-bar-placeholder">说说你的想法…</text>
          </view>
        </view>

      </view>
    </view>

    <!-- 底部划动动作按钮（隐藏，保留结构） -->
    <view class="action-buttons-wrapper">
      <view class="action-col" bindtap="openCommentPanel">
        <view class="circle-btn">
          <image src="/assets/icons/forum.svg" style="width: 34rpx; height: 34rpx; opacity: 0.72;"></image>
        </view>
        <view class="action-text-wrapper action-label">
          <text class="action-hint">COMMENT</text>
          <text class="action-main">评论</text>
        </view>
      </view>
      <view class="center-actions">
        <view class="voice-btn" bindtap="handleVoiceInput">
          <image src="/assets/icons/mic.svg" style="width: 34rpx; height: 34rpx; opacity: 0.8; filter: brightness(0.1);"></image>
        </view>
        <view class="action-text-wrapper action-label center-text">
          <text class="action-hint">AI CALL</text>
          <text class="action-main">连线智能</text>
        </view>
      </view>
      <view class="action-col" bindtap="reduceSimilarTopics">
        <view class="circle-btn">
          <image src="/assets/icons/close.svg" style="width: 30rpx; height: 30rpx; opacity: 0.72;"></image>
        </view>
        <view class="action-text-wrapper action-label">
          <text class="action-hint">FILTER</text>
          <text class="action-main">减少同类</text>
          <text class="action-sub">话题</text>
        </view>
      </view>
    </view>

  </scroll-view>

  <!-- 底部毛玻璃导航条 (三段式) -->
  <view class="bottom-nav">
    <view class="nav-container">
      <view class="nav-glass"></view>
      <view class="nav-content">
        <view class="nav-item" bindtap="goToDiscovery">
          <image src="/assets/icons/wave.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">冲浪</text>
        </view>
        <view class="nav-item active">
          <image src="/assets/icons/cards_stack.svg" class="nav-svg-icon active-icon" mode="aspectFit"></image>
          <text class="nav-text">真心话</text>
        </view>
        <view class="nav-item" bindtap="goToChat">
          <image src="/assets/icons/note.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">小纸条</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 匹配对象仪式感弹窗 -->
  <view class="match-reveal-mask" wx:if="{{showMatchCard}}" catchtouchmove="preventTouchMove" bindtap="closeMatchCard">
    <view class="match-reveal-box" catchtap="preventTouchMove">
      <view class="match-reveal-bg-grid"></view>

      <view class="match-reveal-head">
        <text class="match-reveal-kicker">✦ 同频 SW</text>
        <text class="match-reveal-title">同频匹配成功！</text>
        <view class="match-reveal-subline">
          <text class="match-reveal-sub-mark">✣</text>
          <text class="match-reveal-sub">发现 {{currentMatch.matchScore}}% 频率共鸣</text>
          <text class="match-reveal-sub-mark">✣</text>
        </view>
      </view>

      <view class="match-profile-card">
        <view class="match-photo-wrap">
          <image wx:if="{{currentMatch.photoUrl}}" class="match-photo" src="{{currentMatch.photoUrl}}" mode="aspectFill"></image>
          <view wx:else class="match-photo-word-cloud">
            <view class="match-word-cloud-field">
              <view
                wx:for="{{currentMatch.wordCloud}}"
                wx:key="id"
                class="match-cloud-word"
                style="font-size: {{item.size}}rpx; opacity: {{item.opacity}}; left: {{item.left}}%; top: {{item.top}}%; transform: rotate({{item.rotate}}deg); color: {{item.color}};">
                <text>{{item.word}}</text>
              </view>
              <view class="match-word-cloud-center">
                <text class="match-word-cloud-center-main">三观</text>
                <text class="match-word-cloud-center-sub">词云</text>
              </view>
            </view>
          </view>
          <view class="match-score-pill">
            <text class="match-score-flash">↯</text>
            <text class="match-score-pill-text">高度同频</text>
          </view>
        </view>

        <view class="match-profile-info">
          <view class="match-wx-avatar-row">
            <image class="match-wx-avatar" src="{{currentMatch.wxAvatar}}" mode="aspectFill"></image>
          </view>

          <view class="match-name-row">
            <view class="match-name-block">
              <text class="match-reveal-name">{{currentMatch.name}}, {{currentMatch.age}}</text>
              <text class="match-location">⌖ {{currentMatch.city}}</text>
            </view>
            <view class="match-mbti-pill">
              <text class="match-mbti-text">{{currentMatch.mbti}}</text>
            </view>
          </view>

          <view class="match-reveal-tags">
            <view class="match-reveal-tag" wx:for="{{currentMatch.tags}}" wx:key="index">
              <text class="match-reveal-tag-text"># {{item}}</text>
            </view>
          </view>

          <view class="match-signature-card">
            <text class="match-signature-text">"{{currentMatch.signature}}"</text>
          </view>
        </view>
      </view>

      <view class="match-reveal-actions">
        <view class="match-btn-primary" bindtap="closeMatchCard">
          <text class="match-btn-icon">≡</text>
          <text class="match-btn-text-primary">发个小纸条</text>
        </view>
        <view class="match-btn-secondary" bindtap="closeMatchCard">
          <text class="match-btn-text-secondary">继续冲浪</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 上滑次数耗尽弹窗 -->
  <view class="modal-mask" wx:if="{{showLimitModal}}" catchtouchmove="preventTouchMove">
    <view class="modal-box">
      <text class="modal-title">次数用尽</text>
      <text class="modal-desc">今日基础用户上滑划过功能 (5次) 已用尽，升级三观库解锁无限划卡功能。</text>
      <button class="modal-btn-primary" bindtap="closeModal">确认</button>
    </view>
  </view>

</view>
