/* pages/home/home.wxss */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: #1A1A1A;
}

.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
}

.container {
  position: relative;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Background gradient from design */
.bg-gradient {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, #F8F1E4 0%, #EBE4D5 45%, #E1DAC7 100%);
  z-index: -1;
}

/* Header */
.header {
  width: 100%;
  box-sizing: border-box;
  padding: 0 40rpx 14rpx 40rpx;
}
.header-content {
  display: flex;
  align-items: center;
}
.date-location {
  display: flex;
  flex-direction: column;
}

/* Registered Users Badge */
.registered-users {
  display: flex;
  align-items: center;
  background: rgba(26,26,26,0.06);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  width: max-content;
}
.online-dot {
  width: 10rpx;
  height: 10rpx;
  background: #52C41A;
  border-radius: 50%;
  margin-right: 10rpx;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.4);
}
.registered-users text {
  font-size: 24rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26, 26, 26, 0.85);
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Stories List */
.stories-list {
  width: 100%;
  white-space: nowrap;
  padding: 34rpx 40rpx 0;
  box-sizing: border-box;
}
.story-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 28rpx;
}
.avatar-wrap {
  position: relative;
  width: 122rpx;
  height: 122rpx;
  border-radius: 40rpx;
  padding: 4rpx;
  box-sizing: border-box;
  background: transparent;
  border: 1px solid rgba(0,0,0,0.1);
}
.you-wrap {
  border-color: rgba(0,0,0,0.8);
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 36rpx;
}
.avatar-placeholder {
  background: linear-gradient(135deg, rgba(26,26,26,0.08), rgba(196,184,156,0.18));
}
.badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 24rpx;
  height: 24rpx;
  background: white;
  border-radius: 50%;
  border: 4rpx solid #F5F3ED;
}
.black-badge {
  background: #1A1A1A;
}
.name-text {
  font-size: 16rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  margin-top: 10rpx;
  text-transform: uppercase;
}

/* Categories */
/* Card */
.card-wrapper {
  position: relative;
  padding: 30rpx 40rpx 0;
  height: 958rpx;
  margin-top: 28rpx;
  perspective: 1000px;
}
.card-stack-layer {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(24, 24, 24, 0.04);
  box-shadow: 0 12rpx 22rpx rgba(196, 184, 156, 0.10);
}
.card-stack-layer.back-one {
  top: 10rpx;
  bottom: -2rpx;
  transform: translateY(56rpx) scale(0.94);
  box-shadow: 0 16rpx 30rpx rgba(0,0,0,0.06);
}
.card-stack-layer.back-two {
  top: 10rpx;
  bottom: -4rpx;
  transform: translateY(80rpx) scale(0.90);
  opacity: 0.65;
  box-shadow: 0 16rpx 30rpx rgba(0,0,0,0.04);
}
.card-preview {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 8rpx;
  bottom: -4rpx;
  z-index: 1;
  background: #FFFFFF;
  border-radius: 40rpx;
  border: 1rpx solid rgba(24, 24, 24, 0.06);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08); /* 加深阴影 */
  overflow: hidden;
  transition: transform 0.24s ease, opacity 0.24s ease;
}
.card-preview-body {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  height: 100%;
}
.card-preview-text {
  font-family: 'Noto Serif', serif;
  font-size: 48rpx;
  line-height: 1.24;
  text-align: center;
  color: rgba(0,0,0,0.28);
}
.card-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 0 32rpx;
  flex-shrink: 0;
}
.card-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}
.card-tag {
  background: rgba(196, 184, 156, 0.18);
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
}
.card-tag-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: rgba(26, 26, 26, 0.48);
}
.share-trigger {
  flex-shrink: 0;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: rgba(26,26,26,0.04);
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-trigger-icon {
  font-size: 22rpx;
  font-weight: bold;
  line-height: 1;
}

.card-inner {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.12); /* 加深主卡片阴影 */
  border: 2rpx solid rgba(24, 24, 24, 0.78);
  display: flex;
  flex-direction: column;
}


.card-body {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 64rpx;
}
.opinion-text {
  font-family: 'Noto Serif', serif;
  font-size: 54rpx;
  line-height: 1.24;
  text-align: center;
}

.card-footer {
  padding: 24rpx 32rpx 30rpx;
  border-top: 1px solid rgba(0,0,0,0.03);
}
.vote-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.vote-labels text {
  font-size: 14rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  color: rgba(0,0,0,0.4);
}
.progress-bar-container {
  position: relative;
  height: 68rpx;
  width: 100%;
  margin-top: 12rpx;
}
.progress-bar-bg {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 6rpx;
  background: rgba(0,0,0,0.05);
  border-radius: 6rpx;
}
.progress-bar-fill {
  height: 100%;
  background: #1A1A1A;
  border-radius: 6rpx;
}
.avatars-agree, .avatars-disagree {
  position: absolute;
  top: 0;
  display: flex;
}
.avatars-agree {
  margin-left: -10rpx;
}
.tiny-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #FFF;
  margin-left: -16rpx;
}
.tiny-avatar.single {
  margin-left: 0;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.card-action-pill {
  flex: 1;
  min-height: 90rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: #ECECE8;
  border: 1px solid rgba(0,0,0,0.02);
  box-shadow: none;
  box-sizing: border-box;
}
.card-action-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #F8F8F6;
  border: 1px solid rgba(0,0,0,0.02);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}
.card-action-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.68;
}
.card-action-icon.small {
  width: 24rpx;
  height: 24rpx;
}
.card-action-text {
  margin-left: 14rpx;
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 0.2rpx;
  color: rgba(34,34,34,0.62);
  line-height: 1.25;
}

/* Action Buttons */
.action-buttons-wrapper {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 90rpx;
  margin-top: 100rpx;
  padding: 0 40rpx 24rpx;
  visibility: hidden;
  pointer-events: none;
}
.action-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.circle-btn {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(26,26,26,0.62);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 14rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 20rpx 38rpx rgba(196, 184, 156, 0.18);
}
.action-text-wrapper {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.action-label {
  min-height: 50rpx;
  justify-content: flex-start;
}
.action-hint {
  font-size: 11rpx;
  color: rgba(0,0,0,0.34);
  font-weight: bold;
  letter-spacing: 2.2rpx;
}
.action-main {
  font-size: 15rpx;
  font-weight: bold;
  letter-spacing: 1.1rpx;
  line-height: 1.25;
  margin-top: 6rpx;
}
.action-sub {
  font-size: 15rpx;
  font-weight: bold;
  letter-spacing: 1.1rpx;
  line-height: 1.2;
  margin-top: 2rpx;
}

/* Voice Central Button */
.center-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-bottom: 0;
}
.voice-btn {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #E8EBEF 40%, #C9CDD4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(26,26,26,0.62);
  box-shadow: 0 18rpx 36rpx rgba(180, 185, 192, 0.4), inset 0 4rpx 10rpx rgba(255,255,255,1);
}
.center-text {
  margin-top: 14rpx;
}

/* Bottom Nav Shared */
.bottom-nav { position: fixed; bottom: 52rpx; left: 0; right: 0; display: flex; justify-content: center; z-index: 100; pointer-events: none; }
.nav-container { pointer-events: auto; position: relative; width: 58%; min-width: 520rpx; overflow: hidden; border-radius: 100rpx; box-shadow: 0 14rpx 28rpx rgba(196, 184, 156, 0.08); }
.nav-glass { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,247,243,0.92) 100%); border: 1px solid rgba(255,255,255,0.94); border-radius: 100rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); }
.nav-content { position: relative; z-index: 1; padding: 22rpx 42rpx 18rpx; display: flex; justify-content: space-between; align-items: center; }
.nav-item { display: flex; flex-direction: column; align-items: center; opacity: 1; min-width: 104rpx; }
.nav-svg-icon { width: 44rpx; height: 44rpx; margin-bottom: 10rpx; opacity: 0.5; }
.nav-item.active .nav-svg-icon,
.active-icon { opacity: 1; }

.nav-text { font-size: 20rpx; font-weight: bold; letter-spacing: 1rpx; color: rgba(24,24,24,0.55); }
.nav-item.active .nav-text { color: #1A1A1A; }

/* Modals */
.modal-mask {
  position: fixed;
  top:0; left:0; right:0; bottom:0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}
.modal-box {
  width: 600rpx;
  background: #FFF;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}
.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
}
.modal-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 60rpx;
  line-height: 1.5;
}
.modal-btn-primary {
  background: #1A1A1A;
  color: #FFF;
  border-radius: 100rpx;
  padding: 24rpx 0;
  font-weight: bold;
  font-size: 30rpx;
}

.comment-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  background: rgba(0,0,0,0.36);
  backdrop-filter: blur(10px);
}
.comment-panel {
  width: 100%;
  max-height: 78vh;
  padding: 38rpx 36rpx 48rpx;
  box-sizing: border-box;
  border-radius: 44rpx 44rpx 0 0;
  background: #F8F1E4;
  box-shadow: 0 -24rpx 80rpx rgba(0,0,0,0.16);
}
.comment-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 22rpx;
}
.comment-panel-title {
  font-family: 'Noto Serif', serif;
  font-size: 40rpx;
  font-weight: bold;
  font-style: italic;
}
.comment-panel-close {
  font-size: 24rpx;
  color: rgba(26,26,26,0.48);
  font-weight: bold;
}
.comment-card-text {
  display: block;
  padding: 24rpx 0 28rpx;
  font-family: 'Noto Serif', serif;
  font-size: 30rpx;
  line-height: 1.45;
  color: rgba(26,26,26,0.72);
  border-bottom: 1rpx solid rgba(26,26,26,0.08);
}
.comment-empty {
  padding: 32rpx 0;
  color: rgba(26,26,26,0.46);
  font-size: 24rpx;
}
.comment-list {
  max-height: 360rpx;
  margin: 8rpx 0 20rpx;
}
.comment-row {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(26,26,26,0.06);
}
.comment-author {
  display: block;
  margin-bottom: 10rpx;
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: rgba(26,26,26,0.42);
}
.comment-content {
  display: block;
  font-size: 28rpx;
  line-height: 1.55;
  color: rgba(26,26,26,0.82);
}
.comment-input {
  width: 100%;
  min-height: 150rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: rgba(255,255,255,0.92);
  font-size: 26rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.comment-submit {
  margin: 0;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 999rpx;
  background: #1A1A1A;
  color: #FFF;
  font-size: 26rpx;
  font-weight: bold;
}

.share-mask {
  position: fixed;
  inset: 0;
  z-index: 1001;
  display: flex;
  align-items: flex-end;
  background: rgba(0,0,0,0.38);
  backdrop-filter: blur(10px);
}
.share-panel {
  width: 100%;
  padding: 40rpx 36rpx 46rpx;
  box-sizing: border-box;
  border-radius: 44rpx 44rpx 0 0;
  background: #F8F1E4;
  box-shadow: 0 -24rpx 80rpx rgba(0,0,0,0.16);
}
.share-title {
  display: block;
  font-family: 'Noto Serif', serif;
  font-size: 42rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}
.share-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(26,26,26,0.56);
  margin-bottom: 24rpx;
}
.share-preview {
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255,255,255,0.88);
  border: 1rpx solid rgba(26,26,26,0.06);
  margin-bottom: 24rpx;
}
.share-preview-tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(26,26,26,0.06);
  font-size: 20rpx;
  font-weight: bold;
  margin-bottom: 14rpx;
}
.share-preview-text {
  display: block;
  font-family: 'Noto Serif', serif;
  font-size: 32rpx;
  line-height: 1.5;
  color: rgba(26,26,26,0.82);
}
.share-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 14rpx;
  margin-bottom: 16rpx;
}
.share-btn {
  width: calc(50% - 7rpx);
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  font-weight: bold;
  margin: 0;
}
.share-btn.ghost {
  background: #ECECE8;
  color: rgba(26,26,26,0.78);
}
.share-btn.solid {
  background: #1A1A1A;
  color: #FFF;
}
.share-close {
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  background: transparent;
  color: rgba(26,26,26,0.48);
  font-size: 24rpx;
  font-weight: bold;
}

.poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 720px;
  height: 1160px;
  opacity: 0;
  pointer-events: none;
}
