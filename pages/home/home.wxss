/* pages/home/home.wxss */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: #1A1A1A;
}

.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
}

.container {
  position: relative;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Background gradient from design */
.bg-gradient {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, #F8F1E4 0%, #EBE4D5 45%, #E1DAC7 100%);
  z-index: -1;
}

/* Header */
.header {
  width: 100%;
  box-sizing: border-box;
  padding: 0 40rpx 24rpx 40rpx;
}
.header-content {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}
.date-location {
  display: flex;
  flex-direction: column;
}
.date-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  text-transform: uppercase;
  color: #1A1A1A;
}
.location-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  color: rgba(26,26,26,0.6);
  text-transform: uppercase;
  margin-top: 6rpx;
}

/* Registered Users Badge */
.registered-users {
  display: flex;
  align-items: center;
  background: rgba(26,26,26,0.06);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  width: max-content;
}
.online-dot {
  width: 10rpx;
  height: 10rpx;
  background: #52C41A;
  border-radius: 50%;
  margin-right: 10rpx;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.4);
}
.registered-users text {
  font-size: 16rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  color: rgba(26, 26, 26, 0.85);
}

/* Grid Icon */
.grid-icon {
  display: grid;
  grid-template-columns: repeat(2, 6rpx);
  grid-gap: 6rpx;
  padding-top: 8rpx;
}
.grid-dot {
  width: 6rpx;
  height: 6rpx;
  background-color: #1A1A1A;
  border-radius: 50%;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Stories List */
.stories-list {
  width: 100%;
  white-space: nowrap;
  padding: 0 40rpx;
  box-sizing: border-box;
}
.story-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 28rpx;
}
.avatar-wrap {
  position: relative;
  width: 122rpx;
  height: 122rpx;
  border-radius: 40rpx;
  padding: 4rpx;
  box-sizing: border-box;
  background: transparent;
  border: 1px solid rgba(0,0,0,0.1);
}
.you-wrap {
  border-color: rgba(0,0,0,0.8);
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 36rpx;
}
.badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 24rpx;
  height: 24rpx;
  background: white;
  border-radius: 50%;
  border: 4rpx solid #F5F3ED;
}
.black-badge {
  background: #1A1A1A;
}
.name-text {
  font-size: 16rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  margin-top: 10rpx;
  text-transform: uppercase;
}

/* Categories */
.category-tabs {
  width: 100%;
  white-space: nowrap;
  padding: 28rpx 40rpx 20rpx;
  box-sizing: border-box;
}
.tab-item {
  display: inline-block;
  margin-right: 34rpx;
}
.tab-item text {
  font-size: 18rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  color: rgba(0,0,0,0.4);
  padding-bottom: 10rpx;
}
.tab-item.active text {
  color: #1A1A1A;
  border-bottom: 2rpx solid #1A1A1A;
}

/* Card */
.card-wrapper {
  position: relative;
  padding: 30rpx 40rpx 0;
  height: 706rpx;
  margin-top: 6rpx;
  perspective: 1000px;
}
.card-stack-layer {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(24, 24, 24, 0.04);
  box-shadow: 0 12rpx 22rpx rgba(196, 184, 156, 0.10);
}
.card-stack-layer.back-one {
  top: 10rpx;
  bottom: -2rpx;
  transform: translateY(56rpx) scale(0.94);
  box-shadow: 0 16rpx 30rpx rgba(0,0,0,0.06);
}
.card-stack-layer.back-two {
  top: 10rpx;
  bottom: -4rpx;
  transform: translateY(80rpx) scale(0.90);
  opacity: 0.65;
  box-shadow: 0 16rpx 30rpx rgba(0,0,0,0.04);
}
.card-preview {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 8rpx;
  bottom: -4rpx;
  z-index: 1;
  background: #FFFFFF;
  border-radius: 40rpx;
  border: 1rpx solid rgba(24, 24, 24, 0.06);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08); /* 加深阴影 */
  overflow: hidden;
  transition: transform 0.24s ease, opacity 0.24s ease;
}
.card-preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 32rpx 26rpx;
  border-bottom: 1px solid rgba(0,0,0,0.03);
}
.card-preview-body {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  height: calc(100% - 110rpx);
}
.card-preview-text {
  font-family: 'Noto Serif', serif;
  font-size: 48rpx;
  line-height: 1.24;
  text-align: center;
  color: rgba(0,0,0,0.28);
}
.card-inner {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.12); /* 加深主卡片阴影 */
  border: 2rpx solid rgba(24, 24, 24, 0.78);
  display: flex;
  flex-direction: column;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 32rpx 26rpx;
  border-bottom: 1px solid rgba(0,0,0,0.03);
}
.user-info {
  display: flex;
  align-items: center;
}
.card-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 18rpx;
}
.user-meta {
  display: flex;
  flex-direction: column;
}
.profile-name {
  font-size: 18rpx;
  font-weight: bold;
  letter-spacing: 1.6rpx;
  text-transform: uppercase;
}
.profile-tags {
  margin-top: 6rpx;
  font-size: 15rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  color: rgba(0,0,0,0.42);
  text-transform: uppercase;
}
.share-trigger {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: rgba(26,26,26,0.04);
}
.share-trigger-icon {
  font-size: 22rpx;
  font-weight: bold;
  line-height: 1;
}

.card-body {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 64rpx;
}
.opinion-text {
  font-family: 'Noto Serif', serif;
  font-size: 54rpx;
  line-height: 1.24;
  text-align: center;
}

.card-footer {
  padding: 24rpx 32rpx 30rpx;
  border-top: 1px solid rgba(0,0,0,0.03);
}
.vote-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}
.vote-labels text {
  font-size: 14rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  color: rgba(0,0,0,0.4);
}
.progress-bar-container {
  position: relative;
  height: 68rpx;
  width: 100%;
  margin-top: 12rpx;
}
.progress-bar-bg {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 6rpx;
  background: rgba(0,0,0,0.05);
  border-radius: 6rpx;
}
.progress-bar-fill {
  height: 100%;
  background: #1A1A1A;
  border-radius: 6rpx;
}
.avatars-agree, .avatars-disagree {
  position: absolute;
  top: 0;
  display: flex;
}
.avatars-agree {
  margin-left: -10rpx;
}
.tiny-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #FFF;
  margin-left: -16rpx;
}
.tiny-avatar.single {
  margin-left: 0;
}

/* Action Buttons */
.action-buttons-wrapper {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 90rpx;
  margin-top: 100rpx;
  padding: 0 40rpx 24rpx;
}
.action-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.circle-btn {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(26,26,26,0.62);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 14rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 20rpx 38rpx rgba(196, 184, 156, 0.18);
}
.action-text-wrapper {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.action-label {
  min-height: 50rpx;
  justify-content: flex-start;
}
.action-hint {
  font-size: 11rpx;
  color: rgba(0,0,0,0.34);
  font-weight: bold;
  letter-spacing: 2.2rpx;
}
.action-main {
  font-size: 15rpx;
  font-weight: bold;
  letter-spacing: 1.1rpx;
  line-height: 1.25;
  margin-top: 6rpx;
}
.action-sub {
  font-size: 15rpx;
  font-weight: bold;
  letter-spacing: 1.1rpx;
  line-height: 1.2;
  margin-top: 2rpx;
}

/* Voice Central Button */
.center-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-bottom: 0;
}
.voice-btn {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #E8EBEF 40%, #C9CDD4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(26,26,26,0.62);
  box-shadow: 0 18rpx 36rpx rgba(180, 185, 192, 0.4), inset 0 4rpx 10rpx rgba(255,255,255,1);
}
.center-text {
  margin-top: 14rpx;
}

/* Bottom Nav Shared */
.bottom-nav { position: fixed; bottom: 30rpx; left: 0; right: 0; display: flex; justify-content: center; z-index: 100; pointer-events: none; }
.nav-container { pointer-events: auto; position: relative; width: 58%; min-width: 520rpx; overflow: hidden; border-radius: 100rpx; box-shadow: 0 14rpx 28rpx rgba(196, 184, 156, 0.08); }
.nav-glass { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,247,243,0.92) 100%); border: 1px solid rgba(255,255,255,0.94); border-radius: 100rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); }
.nav-content { position: relative; z-index: 1; padding: 22rpx 42rpx 18rpx; display: flex; justify-content: space-between; align-items: center; }
.nav-item { display: flex; flex-direction: column; align-items: center; opacity: 1; min-width: 104rpx; }
.nav-icon { position: relative; width: 42rpx; height: 42rpx; margin-bottom: 12rpx; box-sizing: border-box; display: flex; justify-content: center; align-items: center;}

/* Cards Icon */
.cards-icon { width: 40rpx; height: 34rpx; border: 4rpx solid rgba(24,24,24,0.6); border-radius: 6rpx; }
.cards-tab { position: absolute; top: -10rpx; left: 8rpx; width: 18rpx; height: 10rpx; border: 4rpx solid rgba(24,24,24,0.6); border-bottom: none; border-radius: 6rpx 6rpx 0 0; background: rgba(255,255,255,0.9); }
.nav-item.active .cards-icon, .nav-item.active .cards-tab { border-color: #1A1A1A; }

/* Chat Icon */
.bubble { width: 36rpx; height: 28rpx; border: 4rpx solid rgba(24,24,24,0.6); border-radius: 12rpx; position: relative;}
.tail { position: absolute; bottom: 0; right: 6rpx; width: 0; height: 0; border-left: 8rpx solid transparent; border-right: 0px solid transparent; border-bottom: 8rpx solid rgba(24,24,24,0.6); transform: translateY(6rpx) translateX(4rpx) rotate(-15deg); }
.nav-item.active .bubble { border-color: #1A1A1A; }
.nav-item.active .tail { border-bottom-color: #1A1A1A; }

/* Surf Icon */
.surf-icon { overflow: hidden; width: 36rpx; height: 36rpx; border: 4rpx solid rgba(24,24,24,0.6); border-radius: 50%; display: flex; justify-content: center; align-items: center;}
.wave { width: 40rpx; height: 20rpx; border-top: 4rpx solid rgba(24,24,24,0.6); border-radius: 50%; transform: translateY(4rpx); }
.nav-item.active .surf-icon { border-color: #1A1A1A; }
.nav-item.active .wave { border-top-color: #1A1A1A; }

.nav-text { font-size: 12rpx; font-weight: bold; letter-spacing: 2.2rpx; color: rgba(24,24,24,0.72); }
.nav-item.active .nav-text { color: #1A1A1A; }

/* Modals */
.modal-mask {
  position: fixed;
  top:0; left:0; right:0; bottom:0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}
.modal-box {
  width: 600rpx;
  background: #FFF;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}
.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
}
.modal-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 60rpx;
  line-height: 1.5;
}
.modal-btn-primary {
  background: #1A1A1A;
  color: #FFF;
  border-radius: 100rpx;
  padding: 24rpx 0;
  font-weight: bold;
  font-size: 30rpx;
}
