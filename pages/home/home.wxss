/* pages/home/home.wxss */
page {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  color: #1A1A1A;
}

.material-symbols-outlined {
  font-variation-settings: 'FILL' 0, 'wght' 300, 'GRAD' 0, 'opsz' 24;
}

.container {
  position: relative;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* Background gradient from design */
.bg-gradient {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(180deg, #F8F1E4 0%, #EBE4D5 45%, #E1DAC7 100%);
  z-index: -1;
}

/* Header */
.header {
  width: 100%;
  box-sizing: border-box;
  padding: 0 40rpx 14rpx 40rpx;
}
.header-content {
  display: flex;
  align-items: center;
}
.date-location {
  display: flex;
  flex-direction: column;
}

/* Registered Users Badge */
.registered-users {
  display: flex;
  align-items: center;
  background: rgba(26,26,26,0.06);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  width: max-content;
}
.online-dot {
  width: 10rpx;
  height: 10rpx;
  background: #52C41A;
  border-radius: 50%;
  margin-right: 10rpx;
  box-shadow: 0 0 8rpx rgba(82, 196, 26, 0.4);
}
.registered-users text {
  font-size: 24rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26, 26, 26, 0.85);
}

/* 心理学测试入口按钮 */
.psych-test-trigger {
  position: fixed;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(26, 26, 26, 0.06);
  border-radius: 999rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
}
.psych-test-icon {
  font-size: 20rpx;
  color: rgba(26,26,26,0.65);
  line-height: 1;
}
.psych-test-label {
  font-size: 22rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26,26,26,0.65);
}

/* 菜单触发按钮 (fixed 定位，position 由 inline style 提供) */
.menu-trigger {
  position: fixed;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(26, 26, 26, 0.06);
  border-radius: 999rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.menu-dot-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
}
.menu-dot {
  width: 8rpx;
  height: 8rpx;
  background: rgba(26, 26, 26, 0.55);
  border-radius: 50%;
}

/* 菜单遮罩 */
.menu-mask {
  position: fixed;
  inset: 0;
  z-index: 90;
}

/* 菜单面板 */
.menu-panel {
  position: fixed;
  right: 28rpx;
  z-index: 100;
  width: 420rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.12);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  padding: 36rpx 32rpx 28rpx;
}
.menu-panel-label {
  display: block;
  font-size: 18rpx;
  font-weight: bold;
  letter-spacing: 3rpx;
  color: rgba(26, 26, 26, 0.38);
  margin-bottom: 24rpx;
}
.menu-categories {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 28rpx;
}
.menu-cat-chip {
  background: rgba(196, 184, 156, 0.18);
  border-radius: 999rpx;
  padding: 14rpx 28rpx;
  border: 1.5rpx solid transparent;
}
.menu-cat-chip.active {
  background: #1A1A1A;
  border-color: #1A1A1A;
}
.menu-cat-text {
  font-size: 24rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26, 26, 26, 0.6);
}
.menu-cat-chip.active .menu-cat-text {
  color: #FFFFFF;
}
.menu-divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.05);
  margin-bottom: 24rpx;
}
.menu-profile-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 4rpx 0;
}
.menu-profile-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #1A1A1A;
}
.menu-profile-arrow {
  font-size: 28rpx;
  color: rgba(26, 26, 26, 0.4);
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* Stories List */
.stories-list {
  width: 100%;
  white-space: nowrap;
  padding: 34rpx 40rpx 0;
  box-sizing: border-box;
}
.story-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 28rpx;
}
.avatar-wrap {
  position: relative;
  width: 122rpx;
  height: 122rpx;
  border-radius: 40rpx;
  padding: 4rpx;
  box-sizing: border-box;
  background: transparent;
  border: 1px solid rgba(0,0,0,0.1);
}
.you-wrap {
  border-color: rgba(0,0,0,0.8);
}
.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 36rpx;
}
.badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 24rpx;
  height: 24rpx;
  background: white;
  border-radius: 50%;
  border: 4rpx solid #F5F3ED;
}
.black-badge {
  background: #1A1A1A;
}
.name-text {
  font-size: 16rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  margin-top: 10rpx;
  text-transform: uppercase;
}

/* Categories */
/* Card */
.card-wrapper {
  position: relative;
  padding: 30rpx 40rpx 0;
  height: 958rpx;
  margin-top: 28rpx;
  perspective: 1000px;
}
.card-stack-layer {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  border-radius: 40rpx;
  background: rgba(255,255,255,0.92);
  border: 1rpx solid rgba(24, 24, 24, 0.04);
  box-shadow: 0 12rpx 22rpx rgba(196, 184, 156, 0.10);
}
.card-stack-layer.back-one {
  top: 10rpx;
  bottom: -2rpx;
  transform: translateY(56rpx) scale(0.94);
  box-shadow: 0 16rpx 30rpx rgba(0,0,0,0.06);
}
.card-stack-layer.back-two {
  top: 10rpx;
  bottom: -4rpx;
  transform: translateY(80rpx) scale(0.90);
  opacity: 0.65;
  box-shadow: 0 16rpx 30rpx rgba(0,0,0,0.04);
}
.card-preview {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  top: 8rpx;
  bottom: -4rpx;
  z-index: 1;
  background: #FFFFFF;
  border-radius: 40rpx;
  border: 1rpx solid rgba(24, 24, 24, 0.06);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08); /* 加深阴影 */
  overflow: hidden;
  transition: transform 0.24s ease, opacity 0.18s ease;
}
.card-preview.is-exiting {
  opacity: 0;
  transform: translateY(42rpx) scale(0.96) !important;
}
.card-wrapper.is-clearing .card-preview,
.card-wrapper.is-clearing .card-stack-layer {
  opacity: 0;
}
.card-preview-body {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx;
  height: 100%;
}
.card-top-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 0 32rpx;
  flex-shrink: 0;
}
.card-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}
.card-tag {
  background: rgba(196, 184, 156, 0.18);
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
}
.card-tag-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: rgba(26, 26, 26, 0.48);
}
.share-trigger {
  flex-shrink: 0;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: rgba(26,26,26,0.04);
  display: flex;
  align-items: center;
  justify-content: center;
}
.share-trigger-icon {
  font-size: 22rpx;
  font-weight: bold;
  line-height: 1;
}

.card-inner {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  background: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 24rpx 70rpx rgba(0, 0, 0, 0.12); /* 加深主卡片阴影 */
  border: 2rpx solid rgba(24, 24, 24, 0.78);
  display: flex;
  flex-direction: column;
}


.card-body {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0 56rpx;
}
.opinion-text {
  font-family: 'Noto Serif', serif;
  font-size: 42rpx;
  line-height: 1.3;
  text-align: center;
}

/* 左右选项区（高度约占卡片1/4） */
.card-options {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  border-top: 1rpx solid rgba(0,0,0,0.06);
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
  height: 240rpx;
  flex-shrink: 0;
}
.card-option-left,
.card-option-right {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 0 28rpx;
}
.card-option-left {
  background: rgba(82, 196, 26, 0.08);
}
.card-option-right {
  background: rgba(255, 77, 79, 0.07);
}
.card-option-divider {
  width: 1rpx;
  background: rgba(0,0,0,0.06);
  flex-shrink: 0;
}
.option-arrow-left,
.option-arrow-right {
  font-size: 40rpx;
  font-weight: bold;
  color: rgba(0,0,0,0.25);
  line-height: 1;
}
.option-label-text {
  font-size: 36rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: rgba(26,26,26,0.75);
}
.agree-text { color: rgba(52,168,83,0.85); }
.disagree-text { color: rgba(220,53,69,0.8); }

.card-footer {
  padding: 20rpx 32rpx 40rpx;
  border-top: none;
}
.progress-bar-container {
  position: relative;
  height: 68rpx;
  width: 100%;
  margin-top: 12rpx;
}
.progress-bar-bg {
  position: absolute;
  bottom: 0;
  width: 100%;
  height: 6rpx;
  background: rgba(0,0,0,0.05);
  border-radius: 6rpx;
}
.progress-bar-fill {
  height: 100%;
  background: #1A1A1A;
  border-radius: 6rpx;
}
.avatars-agree, .avatars-disagree {
  position: absolute;
  top: 0;
  display: flex;
}
.avatars-agree {
  margin-left: -10rpx;
}
.tiny-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 4rpx solid #FFF;
  margin-left: -16rpx;
}
.tiny-avatar.single {
  margin-left: 0;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.card-action-pill {
  flex: 1;
  min-height: 90rpx;
  display: flex;
  align-items: center;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: #ECECE8;
  border: 1px solid rgba(0,0,0,0.02);
  box-shadow: none;
  box-sizing: border-box;
}
.card-action-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #F8F8F6;
  border: 1px solid rgba(0,0,0,0.02);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}
.card-action-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.68;
}
.card-action-icon.small {
  width: 24rpx;
  height: 24rpx;
}
.card-action-text {
  margin-left: 14rpx;
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 0.2rpx;
  color: rgba(34,34,34,0.62);
  line-height: 1.25;
}

/* Action Buttons */
.action-buttons-wrapper {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  gap: 90rpx;
  margin-top: 100rpx;
  padding: 0 40rpx 24rpx;
  visibility: hidden;
  pointer-events: none;
}
.action-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.circle-btn {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(26,26,26,0.62);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 14rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 20rpx 38rpx rgba(196, 184, 156, 0.18);
}
.action-text-wrapper {
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.action-label {
  min-height: 50rpx;
  justify-content: flex-start;
}
.action-hint {
  font-size: 11rpx;
  color: rgba(0,0,0,0.34);
  font-weight: bold;
  letter-spacing: 2.2rpx;
}
.action-main {
  font-size: 15rpx;
  font-weight: bold;
  letter-spacing: 1.1rpx;
  line-height: 1.25;
  margin-top: 6rpx;
}
.action-sub {
  font-size: 15rpx;
  font-weight: bold;
  letter-spacing: 1.1rpx;
  line-height: 1.2;
  margin-top: 2rpx;
}

/* Voice Central Button */
.center-actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding-bottom: 0;
}
.voice-btn {
  width: 112rpx;
  height: 112rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #E8EBEF 40%, #C9CDD4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(26,26,26,0.62);
  box-shadow: 0 18rpx 36rpx rgba(180, 185, 192, 0.4), inset 0 4rpx 10rpx rgba(255,255,255,1);
}
.center-text {
  margin-top: 14rpx;
}

/* Bottom Nav Shared */
.bottom-nav { position: fixed; bottom: 52rpx; left: 0; right: 0; display: flex; justify-content: center; z-index: 100; pointer-events: none; }
.nav-container { pointer-events: auto; position: relative; width: 58%; min-width: 520rpx; overflow: hidden; border-radius: 100rpx; box-shadow: 0 14rpx 28rpx rgba(196, 184, 156, 0.08); }
.nav-glass { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,247,243,0.92) 100%); border: 1px solid rgba(255,255,255,0.94); border-radius: 100rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); }
.nav-content { position: relative; z-index: 1; padding: 22rpx 42rpx 18rpx; display: flex; justify-content: space-between; align-items: center; }
.nav-item { display: flex; flex-direction: column; align-items: center; opacity: 1; min-width: 104rpx; }
.nav-svg-icon { width: 44rpx; height: 44rpx; margin-bottom: 10rpx; opacity: 0.5; }
.nav-item.active .nav-svg-icon,
.active-icon { opacity: 1; }

.nav-text { font-size: 20rpx; font-weight: bold; letter-spacing: 1rpx; color: rgba(24,24,24,0.55); }
.nav-item.active .nav-text { color: #1A1A1A; }

/* ====== 匹配仪式感弹窗 ====== */
@keyframes matchSheetIn {
  0% { opacity: 0; transform: translateY(80rpx) scale(0.98); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes matchAuraShift {
  0%, 100% { opacity: 0.58; transform: translate3d(0, 0, 0); }
  50% { opacity: 0.88; transform: translate3d(0, -10rpx, 0); }
}

.match-reveal-mask {
  position: fixed;
  inset: 0;
  z-index: 998;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 36rpx 58rpx calc(36rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  background:
    radial-gradient(circle at 50% 18%, rgba(196, 184, 156, 0.18) 0%, rgba(245, 243, 237, 0) 42%),
    linear-gradient(180deg, rgba(248, 241, 228, 0.97) 0%, rgba(225, 218, 199, 0.96) 100%);
  backdrop-filter: blur(18px);
}

.match-reveal-box {
  position: relative;
  width: 100%;
  max-width: 628rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow: visible;
  animation: matchSheetIn 0.42s cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.match-reveal-bg-grid {
  position: absolute;
  inset: -120rpx -80rpx;
  pointer-events: none;
  background-image:
    radial-gradient(circle, rgba(196, 184, 156, 0.28) 1.5rpx, transparent 1.5rpx),
    radial-gradient(circle at 20% 25%, rgba(255, 255, 255, 0.38) 0%, transparent 28%),
    radial-gradient(circle at 88% 70%, rgba(225, 218, 199, 0.76) 0%, transparent 26%);
  background-size: 48rpx 48rpx, 100% 100%, 100% 100%;
  animation: matchAuraShift 3.4s ease-in-out infinite;
}

.match-reveal-head {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 8rpx 28rpx;
}

.match-reveal-kicker {
  font-size: 22rpx;
  line-height: 1;
  font-weight: 800;
  color: #1A1A1A;
  letter-spacing: 0;
  margin-bottom: 36rpx;
}

.match-reveal-title {
  font-size: 48rpx;
  line-height: 1.05;
  font-weight: 900;
  color: #1A1A1A;
  letter-spacing: 0;
  text-align: center;
  text-shadow: 0 2rpx 0 rgba(255, 255, 255, 0.72);
}

.match-reveal-subline {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.match-reveal-sub,
.match-reveal-sub-mark {
  font-size: 22rpx;
  line-height: 1.2;
  color: rgba(26, 26, 26, 0.66);
  font-weight: 600;
  letter-spacing: 0;
}

.match-reveal-sub-mark {
  color: rgba(26, 26, 26, 0.42);
  font-size: 24rpx;
}

.match-profile-card {
  position: relative;
  z-index: 1;
  overflow: hidden;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 26rpx 56rpx rgba(196, 184, 156, 0.20);
}

.match-photo-wrap {
  position: relative;
  width: 100%;
  height: 410rpx;
  overflow: hidden;
  background: #E1DAC7;
}

.match-photo {
  width: 100%;
  height: 100%;
  display: block;
}

.match-photo-word-cloud {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 46%, rgba(255, 255, 255, 0.82) 0%, rgba(248, 241, 228, 0.38) 34%, transparent 62%),
    linear-gradient(135deg, #F8F1E4 0%, #E1DAC7 100%);
}

.match-word-cloud-field {
  position: absolute;
  inset: 24rpx 34rpx;
}

.match-cloud-word {
  position: absolute;
  white-space: nowrap;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 0;
}

.match-word-cloud-center {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.match-word-cloud-center-main {
  font-size: 72rpx;
  line-height: 1;
  font-weight: 900;
  color: rgba(26, 26, 26, 0.08);
  letter-spacing: 0;
}

.match-word-cloud-center-sub {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1;
  font-weight: 900;
  color: rgba(26, 26, 26, 0.10);
  letter-spacing: 0;
}

.match-score-pill {
  position: absolute;
  top: 26rpx;
  right: 26rpx;
  height: 48rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 999rpx;
  background: rgba(245, 243, 237, 0.94);
  box-shadow: 0 12rpx 28rpx rgba(26, 26, 26, 0.12);
}

.match-score-flash {
  color: #1A1A1A;
  font-size: 22rpx;
  font-weight: 900;
}

.match-score-pill-text {
  color: #1A1A1A;
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.match-profile-info {
  padding: 26rpx 48rpx 40rpx;
}

.match-wx-avatar-row {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  height: 78rpx;
  margin-bottom: 20rpx;
}

.match-wx-avatar {
  width: 78rpx;
  height: 78rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.96);
  background: #F8F1E4;
  box-shadow: 0 12rpx 26rpx rgba(26, 26, 26, 0.12);
}

.match-name-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.match-name-block {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.match-reveal-name {
  font-size: 34rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #1A1A1A;
  letter-spacing: 0;
}

.match-location {
  font-size: 22rpx;
  line-height: 1.2;
  color: rgba(26, 26, 26, 0.64);
  font-weight: 600;
  letter-spacing: 0;
}

.match-mbti-pill {
  flex-shrink: 0;
  min-width: 96rpx;
  height: 58rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(196, 184, 156, 0.20);
}

.match-mbti-text {
  font-size: 22rpx;
  color: rgba(26, 26, 26, 0.62);
  font-weight: 900;
  letter-spacing: 0;
}

.match-reveal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 30rpx;
}

.match-reveal-tag {
  max-width: 100%;
  min-height: 48rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  border-radius: 999rpx;
  border: 1rpx solid rgba(26, 26, 26, 0.07);
  background: rgba(245, 243, 237, 0.82);
}

.match-reveal-tag:nth-child(3n) {
  background: rgba(196, 184, 156, 0.18);
}

.match-reveal-tag-text {
  font-size: 22rpx;
  line-height: 1.2;
  color: rgba(26, 26, 26, 0.62);
  font-weight: 700;
  letter-spacing: 0;
}

.match-signature-card {
  margin-top: 34rpx;
  padding: 28rpx 34rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: inset 0 0 0 1rpx rgba(26, 26, 26, 0.035);
}

.match-signature-text {
  display: block;
  font-size: 23rpx;
  line-height: 1.65;
  color: rgba(26, 26, 26, 0.74);
  font-weight: 600;
  letter-spacing: 0;
  text-align: center;
}

.match-reveal-actions {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 34rpx;
}

.match-btn-primary,
.match-btn-secondary {
  width: 100%;
  height: 82rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.match-btn-primary {
  background: #1A1A1A;
  box-shadow: 0 18rpx 34rpx rgba(26, 26, 26, 0.20);
}

.match-btn-secondary {
  background: rgba(255, 255, 255, 0.66);
  box-shadow: inset 0 0 0 1rpx rgba(26, 26, 26, 0.05);
}

.match-btn-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 900;
}

.match-btn-text-primary,
.match-btn-text-secondary {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 900;
  letter-spacing: 0;
}

.match-btn-text-primary {
  color: #FFFFFF;
}

.match-btn-text-secondary {
  color: rgba(26, 26, 26, 0.58);
}

/* ====== 新增：我的档案胶囊按钮 ====== */
.profile-capsule-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(26,26,26,0.06);
  border-radius: 999rpx;
  padding: 0 22rpx;
  box-sizing: border-box;
  height: 100%;
}
.profile-capsule-text {
  font-size: 22rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26,26,26,0.65);
}
.profile-capsule-arrow {
  font-size: 22rpx;
  color: rgba(26,26,26,0.45);
}

/* ====== 新增：沙漏菜单图标（SVG 单色版） ====== */
.menu-hourglass-svg {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.7;
}

/* ====== 新增：匹配筛选面板 ====== */
.filter-group {
  margin-bottom: 28rpx;
}
.filter-group-title {
  display: block;
  font-size: 18rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: rgba(26,26,26,0.38);
  margin-bottom: 16rpx;
  text-transform: uppercase;
}
.filter-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.filter-chip {
  background: rgba(196,184,156,0.18);
  border-radius: 999rpx;
  padding: 12rpx 26rpx;
  border: 1.5rpx solid transparent;
}
.filter-chip.active {
  background: #1A1A1A;
  border-color: #1A1A1A;
}
.filter-chip-text {
  font-size: 24rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26,26,26,0.6);
}
.filter-chip.active .filter-chip-text {
  color: #FFFFFF;
}

/* ====== 新增：减少推荐按钮（右上角） ====== */
.reduce-trigger {
  flex-shrink: 0;
  width: 54rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: rgba(26,26,26,0.04);
  display: flex;
  align-items: center;
  justify-content: center;
}
.reduce-trigger-icon {
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
  color: rgba(26,26,26,0.45);
}

/* ====== 新增：进度条细版（无头像） ====== */
/* position: relative 必须设置，防止子元素 .progress-bar-bg (absolute) 越级定位到 card-inner */
.progress-bar-slim-wrap {
  position: relative;
  width: 100%;
  height: 6rpx;
  margin: 14rpx 0 16rpx;
}

/* ====== 新增：通栏评论入口 ====== */
.comment-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
  height: 72rpx;
  background: rgba(26,26,26,0.04);
  border-radius: 20rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  gap: 16rpx;
}
.comment-bar-icon-wrap {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.comment-bar-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}
.comment-bar-placeholder {
  font-size: 26rpx;
  color: rgba(26,26,26,0.35);
  letter-spacing: 0.5rpx;
  font-weight: 500;
}

/* Modals */
.modal-mask {
  position: fixed;
  top:0; left:0; right:0; bottom:0;
  background: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10px);
}
.modal-box {
  width: 600rpx;
  background: #FFF;
  border-radius: 40rpx;
  padding: 60rpx 40rpx;
  text-align: center;
}
.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  display: block;
}
.modal-desc {
  font-size: 28rpx;
  color: #666;
  display: block;
  margin-bottom: 60rpx;
  line-height: 1.5;
}
.modal-btn-primary {
  background: #1A1A1A;
  color: #FFF;
  border-radius: 100rpx;
  padding: 24rpx 0;
  font-weight: bold;
  font-size: 30rpx;
}
