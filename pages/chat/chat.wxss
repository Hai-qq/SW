/* pages/chat/chat.wxss */
page { color: #1A1A1A; font-family: -apple-system, sans-serif; background: transparent; min-height: 100vh; }

.container {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  background: linear-gradient(180deg, #F8F1E4 0%, #EBE4D5 45%, #E1DAC7 100%);
  z-index: -1;
}

/* Header */
.header {
  padding: 0 40rpx 48rpx;
  display: flex;
  align-items: flex-end;
}
.page-title {
  font-family: 'Noto Serif', serif;
  font-size: 56rpx;
  font-weight: bold;
  font-style: italic;
}

/* 撰写按钮：fixed 定位，紧贴系统胶囊左侧 */
.compose-btn-fixed {
  position: fixed;
  z-index: 50;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(26,26,26,0.06);
  border-radius: 999rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
}
.compose-svg { width: 28rpx; height: 28rpx; opacity: 0.7; }

/* 主列表 */
.chat-list {
  flex: 1;
  padding: 0 0 160rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 新朋友/访客入口区 */
.notify-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 0 40rpx 28rpx;
}
/* 新朋友/访客 通知卡片 — 纵向布局 */
.notify-card {
  flex: 1;
  background: rgba(255,255,255,0.92);
  border-radius: 32rpx;
  padding: 24rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  box-shadow: 0 8rpx 28rpx rgba(196,184,156,0.12);
  border: 1.5rpx solid rgba(255,255,255,0.8);
}

/* 标题行：图标 + 名称 + badge */
.notify-card-top {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
}
.notify-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.notify-friend-bg { background: rgba(82,196,26,0.12); }
.notify-visitor-bg { background: rgba(24,144,255,0.10); }
.notify-icon { font-size: 28rpx; }
.notify-title {
  flex: 1;
  font-size: 26rpx;
  font-weight: bold;
  color: #1A1A1A;
  letter-spacing: 1rpx;
}

/* badge 内联在标题行右侧，不干扰布局 */
.notify-count-badge {
  flex-shrink: 0;
  min-width: 36rpx;
  height: 36rpx;
  background: #FF4D4F;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
  box-sizing: border-box;
}
.visitor-badge { background: #1890FF; }
.notify-badge-text { font-size: 18rpx; font-weight: bold; color: #FFF; }

/* 描述文字：对齐图标右侧，单行省略 */
.notify-desc {
  font-size: 20rpx;
  color: rgba(26,26,26,0.45);
  letter-spacing: 0.5rpx;
  padding-left: 74rpx; /* icon(60) + gap(14) */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

/* 分隔线 */
.section-divider {
  padding: 0 40rpx 16rpx;
}
.section-divider-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 3rpx;
  color: rgba(26,26,26,0.35);
}

/* 会话条 */
.chat-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.92);
  border-radius: 36rpx;
  padding: 28rpx 32rpx;
  margin: 0 40rpx 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(196,184,156,0.12);
  border: 1.5rpx solid rgba(255,255,255,0.8);
  position: relative;
}
.avatar-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
}
.online-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 22rpx;
  height: 22rpx;
  background: #52C41A;
  border-radius: 50%;
  border: 3rpx solid #FFF;
}

.chat-info {
  flex: 1;
  overflow: hidden;
  margin-right: 16rpx;
}
.chat-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.chat-name {
  font-weight: bold;
  font-size: 30rpx;
  color: #1A1A1A;
  letter-spacing: 0.5rpx;
}
.chat-time {
  font-size: 20rpx;
  color: rgba(26,26,26,0.3);
  font-weight: bold;
  letter-spacing: 1rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.chat-preview {
  font-size: 24rpx;
  color: rgba(26,26,26,0.5);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

/* 右侧三观档案按钮 wrap（用于角标定位） */
.chat-profile-btn-wrap {
  position: relative;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.chat-profile-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(196,184,156,0.18);
  gap: 4rpx;
}
.chat-profile-icon {
  font-size: 22rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.55);
  line-height: 1;
}
.chat-profile-svg {
  width: 30rpx;
  height: 30rpx;
  opacity: 0.55;
}
.chat-profile-label {
  font-size: 16rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.45);
  letter-spacing: 0.5rpx;
}

/* 未读角标：叠在头像右上角 */
.unread-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #FF4D4F;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  border: 3rpx solid #F8F1E4;
  z-index: 10;
}
.unread-text { font-size: 18rpx; font-weight: bold; color: #FFF; }

/* Bottom Nav Shared */
.bottom-nav { position: fixed; bottom: 52rpx; left: 0; right: 0; display: flex; justify-content: center; z-index: 100; pointer-events: none; }
.nav-container { pointer-events: auto; position: relative; width: 58%; min-width: 520rpx; overflow: hidden; border-radius: 100rpx; box-shadow: 0 14rpx 28rpx rgba(196, 184, 156, 0.08); }
.nav-glass { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,247,243,0.92) 100%); border: 1px solid rgba(255,255,255,0.94); border-radius: 100rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); }
.nav-content { position: relative; z-index: 1; padding: 22rpx 42rpx 18rpx; display: flex; justify-content: space-between; align-items: center; }
.nav-item { display: flex; flex-direction: column; align-items: center; opacity: 1; min-width: 104rpx; }
.nav-svg-icon { width: 44rpx; height: 44rpx; margin-bottom: 10rpx; opacity: 0.5; }
.nav-item.active .nav-svg-icon,
.active-icon { opacity: 1; }
.nav-text { font-size: 20rpx; font-weight: bold; letter-spacing: 1rpx; color: rgba(24,24,24,0.55); }
.nav-item.active .nav-text { color: #1A1A1A; }
