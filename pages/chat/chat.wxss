/* pages/chat/chat.wxss */
page { color: #1A1A1A; font-family: -apple-system, sans-serif; background: transparent; min-height: 100vh; }

.container {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  background: linear-gradient(180deg, #F8F1E4 0%, #EBE4D5 45%, #E1DAC7 100%);
  z-index: -1;
}

/* Header */
.header {
  padding: 16rpx 40rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}
.page-title {
  font-family: 'Noto Serif', serif;
  font-size: 56rpx;
  font-weight: bold;
  font-style: italic;
}
.header-right { display: flex; align-items: center; }
.new-compose-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(26,26,26,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}
.compose-icon { font-size: 30rpx; color: rgba(26,26,26,0.7); }

/* 主列表 */
.chat-list {
  flex: 1;
  padding: 0 0 240rpx;
  box-sizing: border-box;
  width: 100%;
}

/* 新朋友/访客入口区 */
.notify-row {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  padding: 0 40rpx 28rpx;
}
.notify-card {
  flex: 1;
  background: rgba(255,255,255,0.92);
  border-radius: 32rpx;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 28rpx rgba(196,184,156,0.12);
  border: 1.5rpx solid rgba(255,255,255,0.8);
  position: relative;
  overflow: hidden;
}
.notify-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.notify-friend-bg { background: rgba(82,196,26,0.12); }
.notify-visitor-bg { background: rgba(24,144,255,0.10); }
.notify-icon { font-size: 32rpx; }
.notify-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.notify-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #1A1A1A;
  letter-spacing: 1rpx;
}
.notify-desc {
  font-size: 20rpx;
  color: rgba(26,26,26,0.45);
  letter-spacing: 0.5rpx;
}
.notify-badge {
  position: absolute;
  top: 16rpx;
  right: 38rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #FF4D4F;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}
.visitor-badge { background: #1890FF; }
.notify-badge-text { font-size: 20rpx; font-weight: bold; color: #FFF; }
.notify-arrow { font-size: 36rpx; color: rgba(26,26,26,0.25); margin-left: auto; }

/* 分隔线 */
.section-divider {
  padding: 0 40rpx 16rpx;
}
.section-divider-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 3rpx;
  color: rgba(26,26,26,0.35);
}

/* 会话条 */
.chat-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.92);
  border-radius: 36rpx;
  padding: 28rpx 32rpx;
  margin: 0 40rpx 20rpx;
  box-shadow: 0 8rpx 28rpx rgba(196,184,156,0.12);
  border: 1.5rpx solid rgba(255,255,255,0.8);
  position: relative;
}
.avatar-wrap {
  position: relative;
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 32rpx;
}
.online-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 22rpx;
  height: 22rpx;
  background: #52C41A;
  border-radius: 50%;
  border: 3rpx solid #FFF;
}

.chat-info {
  flex: 1;
  overflow: hidden;
  margin-right: 16rpx;
}
.chat-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.chat-name {
  font-weight: bold;
  font-size: 30rpx;
  color: #1A1A1A;
  letter-spacing: 0.5rpx;
}
.chat-time {
  font-size: 20rpx;
  color: rgba(26,26,26,0.3);
  font-weight: bold;
  letter-spacing: 1rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}
.chat-preview {
  font-size: 24rpx;
  color: rgba(26,26,26,0.5);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.4;
}

/* 右侧三观档案按钮 */
.chat-profile-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(196,184,156,0.18);
  flex-shrink: 0;
  margin-left: 16rpx;
  gap: 4rpx;
}
.chat-profile-icon {
  font-size: 22rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.55);
  line-height: 1;
}
.chat-profile-label {
  font-size: 16rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.45);
  letter-spacing: 0.5rpx;
}

/* 未读角标 */
.unread-badge {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  min-width: 36rpx;
  height: 36rpx;
  background: #FF4D4F;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}
.unread-text { font-size: 20rpx; font-weight: bold; color: #FFF; }

/* Bottom Nav Shared */
.bottom-nav { position: fixed; bottom: 52rpx; left: 0; right: 0; display: flex; justify-content: center; z-index: 100; pointer-events: none; }
.nav-container { pointer-events: auto; position: relative; width: 58%; min-width: 520rpx; overflow: hidden; border-radius: 100rpx; box-shadow: 0 14rpx 28rpx rgba(196, 184, 156, 0.08); }
.nav-glass { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,247,243,0.92) 100%); border: 1px solid rgba(255,255,255,0.94); border-radius: 100rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); }
.nav-content { position: relative; z-index: 1; padding: 22rpx 42rpx 18rpx; display: flex; justify-content: space-between; align-items: center; }
.nav-item { display: flex; flex-direction: column; align-items: center; opacity: 1; min-width: 104rpx; }
.nav-svg-icon { width: 44rpx; height: 44rpx; margin-bottom: 10rpx; opacity: 0.5; }
.nav-item.active .nav-svg-icon,
.active-icon { opacity: 1; }
.nav-text { font-size: 20rpx; font-weight: bold; letter-spacing: 1rpx; color: rgba(24,24,24,0.55); }
.nav-item.active .nav-text { color: #1A1A1A; }
