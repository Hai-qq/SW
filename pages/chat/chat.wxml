<!-- pages/chat/chat.wxml -->
<view class="container" style="padding-top: {{statusBarHeight}}px;">
  <view class="bg-gradient"></view>

  <!-- 顶部标题 -->
  <view class="header">
    <text class="page-title" style="margin-top: {{headerInnerMT}}px; height: {{menuTriggerH}}px; display:flex; align-items:center;">小纸条</text>
  </view>

  <!-- 撰写按钮：fixed 定位，紧贴系统胶囊左侧 -->
  <view
    class="compose-btn-fixed"
    style="right: {{menuTriggerRight}}px; top: {{menuTriggerTop}}px; height: {{menuTriggerH}}px;"
    bindtap="openNewChat">
    <image src="/assets/icons/compose.svg" class="compose-svg" mode="aspectFit"></image>
  </view>

  <scroll-view scroll-y="true" enable-flex class="chat-list">

    <!-- 3.3 新朋友 & 访客入口（固定在最顶部） -->
    <view class="notify-row">
      <view class="notify-card" bindtap="openNewFriends">
        <view class="notify-card-top">
          <view class="notify-icon-wrap notify-friend-bg">
            <text class="notify-icon">👋</text>
          </view>
          <text class="notify-title">新朋友</text>
          <view class="notify-count-badge" wx:if="{{newFriendCount > 0}}">
            <text class="notify-badge-text">{{newFriendCount}}</text>
          </view>
        </view>
        <text class="notify-desc">有 {{newFriendCount}} 人发来认识邀请</text>
      </view>

      <view class="notify-card" bindtap="openVisitors">
        <view class="notify-card-top">
          <view class="notify-icon-wrap notify-visitor-bg">
            <text class="notify-icon">👁</text>
          </view>
          <text class="notify-title">访客</text>
          <view class="notify-count-badge visitor-badge" wx:if="{{visitorCount > 0}}">
            <text class="notify-badge-text">{{visitorCount}}</text>
          </view>
        </view>
        <text class="notify-desc">{{visitorCount}} 人查看了你的档案</text>
      </view>
    </view>

    <!-- 分隔线 -->
    <view class="section-divider">
      <text class="section-divider-text">消息</text>
    </view>

    <!-- 3.1 会话列表 -->
    <view
      class="chat-item"
      wx:for="{{chatList}}"
      wx:key="id"
      bindtap="openChatDetail"
      data-id="{{item.id}}">

      <!-- 头像（未读角标贴在头像右上角） -->
      <view class="avatar-wrap">
        <image class="avatar-img" src="{{item.avatar}}" mode="aspectFill"></image>
        <view class="online-badge" wx:if="{{item.isOnline}}"></view>
        <view class="unread-badge" wx:if="{{item.unreadCount > 0}}">
          <text class="unread-text">{{item.unreadCount}}</text>
        </view>
      </view>

      <!-- 聊天信息 -->
      <view class="chat-info">
        <view class="chat-name-row">
          <text class="chat-name">{{item.name}}</text>
          <text class="chat-time">{{item.lastTime}}</text>
        </view>
        <text class="chat-preview">{{item.lastMsg}}</text>
      </view>

      <!-- 右侧三观档案入口 -->
      <view class="chat-profile-btn-wrap">
        <view class="chat-profile-btn" bindtap="openUserProfile" data-id="{{item.id}}" catchtap="openUserProfile">
          <image src="/assets/icons/person.svg" class="chat-profile-svg" mode="aspectFit"></image>
          <text class="chat-profile-label">档案</text>
        </view>
      </view>
    </view>

  </scroll-view>

  <!-- 底部毛玻璃导航条 -->
  <view class="bottom-nav">
    <view class="nav-container">
      <view class="nav-glass"></view>
      <view class="nav-content">
        <view class="nav-item" bindtap="goToDiscovery">
          <image src="/assets/icons/wave.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">冲浪</text>
        </view>
        <view class="nav-item" bindtap="goToHome">
          <image src="/assets/icons/cards_stack.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">真心话</text>
        </view>
        <view class="nav-item active">
          <image src="/assets/icons/note.svg" class="nav-svg-icon active-icon" mode="aspectFit"></image>
          <text class="nav-text">小纸条</text>
        </view>
      </view>
    </view>
  </view>
</view>
