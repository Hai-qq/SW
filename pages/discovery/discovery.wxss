/* pages/discovery/discovery.wxss */
page { color: #1A1A1A; font-family: -apple-system, sans-serif; background: transparent; min-height: 100vh; }

.container { position: relative; width: 100%; display: flex; flex-direction: column; overflow: hidden; }

.bg-gradient {
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  background: linear-gradient(180deg, #F8F1E4 0%, #EBE4D5 45%, #E1DAC7 100%);
  z-index: -1;
}

/* Header */
.header {
  width: 100%;
  position: fixed;
  top: 0;
  z-index: 50;
  background: rgba(248,241,228,0.95);
  backdrop-filter: blur(12px);
  box-sizing: border-box;
}
.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
}
.logo-text {
  font-family: 'Noto Serif', serif;
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: -1rpx;
}
.avatar { width: 64rpx; height: 64rpx; border-radius: 50%; }

/* 三子 Tab */
.sub-tabs {
  display: flex;
  flex-direction: row;
  padding: 0 40rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}
.sub-tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 0 16rpx;
  position: relative;
}
.sub-tab-text {
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: rgba(26,26,26,0.4);
}
.sub-tab-item.active .sub-tab-text {
  color: #1A1A1A;
}
.sub-tab-indicator {
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 3rpx;
  background: #1A1A1A;
  border-radius: 999rpx;
}

/* Main Scroll */
.main-scroll { flex: 1; padding-bottom: 240rpx; }

/* 区块标签 */
.section-label {
  padding: 36rpx 40rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.section-label-text {
  font-family: 'Noto Serif', serif;
  font-size: 38rpx;
  font-weight: bold;
}
.section-label-sub {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  color: rgba(26,26,26,0.4);
}

/* ===== 热议卡片 ===== */
.hot-card {
  margin: 0 40rpx 24rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 36rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
  box-shadow: 0 8rpx 32rpx rgba(196,184,156,0.10);
}
.hot-card.top10 {
  border: 1.5rpx solid rgba(255,100,30,0.15);
  box-shadow: 0 8rpx 32rpx rgba(255,100,30,0.06);
}
.hot-rank-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
}
.hot-rank-badge {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}
.hot-rank-badge.rank-top3 {
  background: #1A1A1A;
}
.hot-rank-num {
  font-size: 22rpx;
  font-weight: bold;
  color: rgba(0,0,0,0.5);
}
.hot-rank-badge.rank-top3 .hot-rank-num {
  color: #FFFFFF;
}
.hot-fire-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: rgba(255,100,30,0.10);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}
.hot-fire-icon { font-size: 22rpx; }
.hot-fire-label {
  font-size: 20rpx;
  font-weight: bold;
  color: rgba(255,80,20,0.85);
  letter-spacing: 1rpx;
}
.hot-gender-diff {
  background: rgba(138,43,226,0.08);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}
.hot-gender-text {
  font-size: 20rpx;
  font-weight: bold;
  color: rgba(138,43,226,0.75);
  letter-spacing: 1rpx;
}
.hot-content {
  font-family: 'Noto Serif', serif;
  font-size: 36rpx;
  line-height: 1.5;
  color: #1A1A1A;
  display: block;
  margin-bottom: 24rpx;
}
.hot-stats-row { margin-bottom: 20rpx; }
.hot-progress-wrap {}
.hot-progress-bg {
  width: 100%;
  height: 6rpx;
  background: rgba(0,0,0,0.06);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}
.hot-progress-fill { height: 100%; background: #1A1A1A; border-radius: 6rpx; }
.hot-progress-labels {
  display: flex;
  justify-content: space-between;
}
.hot-label-left, .hot-label-right {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(0,0,0,0.45);
}
.hot-meta-row {
  display: flex;
  flex-direction: row;
  gap: 28rpx;
}
.hot-meta-item {
  font-size: 20rpx;
  color: rgba(0,0,0,0.38);
  font-weight: bold;
  letter-spacing: 0.5rpx;
}

/* ===== 树洞卡片 ===== */
.cave-card {
  margin: 0 40rpx 24rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 36rpx;
  box-shadow: 0 8rpx 32rpx rgba(196,184,156,0.10);
}
.cave-user-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}
.cave-avatar-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.cave-avatar-emoji { font-size: 36rpx; }
.cave-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.cave-nickname {
  font-size: 26rpx;
  font-weight: bold;
  color: #1A1A1A;
  letter-spacing: 1rpx;
}
.cave-time {
  font-size: 20rpx;
  color: rgba(0,0,0,0.38);
  letter-spacing: 1rpx;
}
.cave-anon-badge {
  background: rgba(0,0,0,0.05);
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
}
.cave-anon-text {
  font-size: 20rpx;
  font-weight: bold;
  color: rgba(0,0,0,0.4);
  letter-spacing: 1rpx;
}
.cave-content {
  font-family: 'Noto Serif', serif;
  font-size: 34rpx;
  line-height: 1.65;
  color: rgba(0,0,0,0.82);
  display: block;
  margin-bottom: 28rpx;
}
.cave-actions {
  display: flex;
  flex-direction: row;
  gap: 32rpx;
  border-top: 1rpx solid rgba(0,0,0,0.04);
  padding-top: 20rpx;
}
.cave-action-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
}
.cave-action-icon {
  font-size: 28rpx;
  color: rgba(0,0,0,0.35);
}
.cave-action-count {
  font-size: 22rpx;
  color: rgba(0,0,0,0.38);
  font-weight: bold;
  letter-spacing: 0.5rpx;
}
.cave-publish-btn {
  margin: 16rpx 40rpx 40rpx;
  height: 96rpx;
  border: 1.5rpx dashed rgba(0,0,0,0.18);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cave-publish-text {
  font-size: 28rpx;
  font-weight: bold;
  color: rgba(0,0,0,0.38);
  letter-spacing: 2rpx;
}

/* ===== 广场 ===== */
.square-filter-scroll {
  white-space: nowrap;
  padding: 0 40rpx 28rpx;
  box-sizing: border-box;
}
.square-filter-chip {
  display: inline-flex;
  align-items: center;
  margin-right: 16rpx;
  background: rgba(196,184,156,0.18);
  border-radius: 999rpx;
  padding: 14rpx 30rpx;
  border: 1.5rpx solid transparent;
}
.square-filter-chip.active {
  background: #1A1A1A;
}
.square-filter-text {
  font-size: 24rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26,26,26,0.6);
}
.square-filter-chip.active .square-filter-text {
  color: #FFFFFF;
}
.square-grid {
  padding: 0 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.square-item {
  background: #FFFFFF;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(196,184,156,0.10);
}
.square-img-wrap {
  position: relative;
  width: 100%;
  height: 340rpx;
}
.square-img-placeholder {
  width: 100%;
  height: 100%;
}
.square-category-tag {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: rgba(0,0,0,0.48);
  border-radius: 999rpx;
  padding: 10rpx 22rpx;
}
.square-category-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 1.5rpx;
  color: rgba(255,255,255,0.9);
}
.square-item-footer { padding: 28rpx 32rpx 24rpx; }
.square-user-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 14rpx;
}
.square-user-avatar-emoji { font-size: 30rpx; }
.square-username {
  font-size: 24rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.65);
  letter-spacing: 1rpx;
}
.square-caption {
  font-size: 30rpx;
  line-height: 1.5;
  color: #1A1A1A;
  display: block;
  margin-bottom: 14rpx;
}
.square-item-meta {}
.square-meta-like {
  font-size: 22rpx;
  color: rgba(0,0,0,0.38);
  font-weight: bold;
}

/* FAB */
.fab {
  position: fixed;
  bottom: 200rpx;
  right: 40rpx;
  width: 110rpx;
  height: 110rpx;
  background: #1A1A1A;
  border-radius: 50%;
  color: #FFF;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 40rpx 80rpx rgba(0,0,0,0.2);
  z-index: 60;
}
.fab-icon { font-size: 60rpx; font-weight: 300; color: #FFF; }

/* Bottom Nav Shared */
.bottom-nav { position: fixed; bottom: 52rpx; left: 0; right: 0; display: flex; justify-content: center; z-index: 100; pointer-events: none; }
.nav-container { pointer-events: auto; position: relative; width: 58%; min-width: 520rpx; overflow: hidden; border-radius: 100rpx; box-shadow: 0 14rpx 28rpx rgba(196, 184, 156, 0.08); }
.nav-glass { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,247,243,0.92) 100%); border: 1px solid rgba(255,255,255,0.94); border-radius: 100rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); }
.nav-content { position: relative; z-index: 1; padding: 22rpx 42rpx 18rpx; display: flex; justify-content: space-between; align-items: center; }
.nav-item { display: flex; flex-direction: column; align-items: center; opacity: 1; min-width: 104rpx; }
.nav-svg-icon { width: 44rpx; height: 44rpx; margin-bottom: 10rpx; opacity: 0.5; }
.nav-item.active .nav-svg-icon,
.active-icon { opacity: 1; }
.nav-text { font-size: 20rpx; font-weight: bold; letter-spacing: 1rpx; color: rgba(24,24,24,0.55); }
.nav-item.active .nav-text { color: #1A1A1A; }

/* ====== 新增：热议双行进度条 ====== */
.hot-dual-progress {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 100%;
  margin-top: 8rpx;
}
.hot-dual-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}
.hot-dual-label {
  font-size: 20rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.45);
  letter-spacing: 1rpx;
  width: 72rpx;
  flex-shrink: 0;
}
.hot-dual-bar-bg {
  flex: 1;
  height: 10rpx;
  background: rgba(0,0,0,0.06);
  border-radius: 10rpx;
  overflow: hidden;
}
.hot-dual-bar-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.4s ease;
}
.agree-fill {
  background: #1A1A1A;
}
.disagree-fill {
  background: rgba(26,26,26,0.28);
}
.hot-dual-pct {
  font-size: 22rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.55);
  letter-spacing: 0.5rpx;
  width: 64rpx;
  text-align: right;
  flex-shrink: 0;
}
