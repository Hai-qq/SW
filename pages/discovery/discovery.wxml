<!-- pages/discovery/discovery.wxml -->
<view class="container" style="min-height: {{windowHeight}}px; background: linear-gradient(180deg, #F5F3ED 0%, #E2E8E4 100%);">
  
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="icon-btn" bindtap="openSideMenu"><text style="font-size: 40rpx; font-weight: 300;">☰</text></view>
      <text class="logo-text">Same Wavelength</text>
      <image wx:if="{{hasHeaderAvatar}}" class="avatar" src="{{headerAvatar}}" mode="aspectFill"></image>
      <view wx:if="{{!hasHeaderAvatar}}" class="avatar"></view>
    </view>
  </view>

  <view wx:if="{{showSideMenu}}" class="side-menu-mask" catchtap="closeSideMenu" catchtouchmove="preventTouchMove"></view>
  <view wx:if="{{showSideMenu}}" class="side-menu-panel" style="padding-top: calc({{statusBarHeight}}px + 48rpx);" catchtap="noop">
    <text class="side-menu-kicker">Same Wavelength</text>
    <text class="side-menu-title">冲浪菜单</text>
    <view class="side-menu-list">
      <view class="side-menu-item" bindtap="goToProfile">
        <text>我的档案</text>
        <text class="side-menu-arrow">→</text>
      </view>
      <view class="side-menu-item" bindtap="goToSettings">
        <text>设置</text>
        <text class="side-menu-arrow">→</text>
      </view>
    </view>
  </view>

  <scroll-view scroll-y="true" class="main-scroll" style="padding-top: calc({{statusBarHeight}}px + 108rpx);">
    <!-- Tabs -->
    <scroll-view scroll-x="true" class="tabs" show-scrollbar="false">
      <view
        wx:for="{{tabItems}}"
        wx:key="label"
        class="{{item.tabClass}}"
        data-tab="{{item.label}}"
        bindtap="switchTab"
      >
        <text>{{item.label}}</text>
      </view>
    </scroll-view>

    <!-- Featured Thoughts Section -->
    <view class="section">
      <view class="section-title">
        <text class="title-text">Hot Waves (热门)</text>
        <text style="font-size: 32rpx; color: #8c8c8c;">⋯</text>
      </view>

      <view class="thought-card" wx:if="{{featuredCard}}">
        <view class="card-top">
          <text class="card-title">{{featuredCard.titleText}}</text>
          <text style="font-size: 32rpx; color: #8C8C8C;">⋯</text>
        </view>
        <view class="stats">
          <view class="progress-bar-bg">
            <view class="progress-bar-fill" style="width: {{featuredCard.progressPercent}}%;"></view>
          </view>
          <view class="stats-text">
            <text class="black-text">{{featuredCard.categoryText}}</text>
            <text>{{featuredCard.statsText}}</text>
          </view>
        </view>
        <view class="avatars-group">
          <view class="stack">
            <image wx:if="{{featuredCard.hasAvatar}}" class="small-av" src="{{featuredCard.avatar}}"></image>
            <view wx:if="{{!featuredCard.hasAvatar}}" class="small-av"></view>
            <view class="small-av more-av">{{featuredCard.likeCountText}}</view>
          </view>
          <text class="hint-msg">正在共鸣中...</text>
        </view>
        <view class="card-quote">
          <text>{{featuredCard.quoteText}}</text>
        </view>
        <view class="discovery-actions">
          <button class="discovery-action-btn primary" bindtap="likeFeatured">{{featuredCard.likeButtonText}}</button>
          <button class="discovery-action-btn" bindtap="openFeaturedComments">查看评论</button>
        </view>
      </view>

    </view>

    <!-- Timeline Section -->
    <view class="section timeline-section">
      <view class="section-title">
        <text class="title-text">Surfing Feed</text>
        <view class="toolbar-actions">
          <button class="mini-action-btn" bindtap="toggleMyPosts">我的发布</button>
          <button class="mini-action-btn" bindtap="openPublish">写一条</button>
        </view>
      </view>

      <view wx:if="{{myPostsVisible}}" class="my-posts-panel">
        <scroll-view scroll-x="true" class="my-post-filters" show-scrollbar="false">
          <view
            wx:for="{{myPostFilterItems}}"
            wx:key="label"
            class="{{item.filterClass}}"
            data-status="{{item.label}}"
            bindtap="switchMyPostFilter"
          >
            <text>{{item.label}}</text>
          </view>
        </scroll-view>

        <view wx:if="{{myPostsEmpty}}" class="my-post-empty">
          <text>这里还没有内容，先存一条草稿试试。</text>
        </view>

        <view wx:for="{{myPosts}}" wx:key="feedId" class="my-post-card">
          <view class="my-post-header">
            <text class="{{item.statusClass}}">{{item.statusText}}</text>
            <text class="my-post-category">{{item.category}}</text>
          </view>
          <text class="my-post-content">{{item.content}}</text>
          <text class="my-post-time">{{item.createdAt}}</text>
        </view>
      </view>

      <view class="timeline">
        <view class="timeline-line"></view>
        
        <view class="timeline-item" wx:for="{{timelineItems}}" wx:key="feedId">
          <view class="timeline-dot {{item.dotClass}}"></view>
          <text class="timeline-meta">{{item.metaText}}</text>
          <text class="timeline-content">{{item.content}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="fab" bindtap="openPublish">
    <text style="font-size: 48rpx; font-weight: 300;">＋</text>
  </view>

  <view wx:if="{{showComposer}}" class="composer-mask">
    <view class="composer-panel">
      <text class="composer-title">写下此刻的想法</text>
      <text class="composer-subtitle">你可以先存草稿，也可以直接发布到公开内容流。</text>
      <textarea
        class="composer-input"
        value="{{publishContent}}"
        bindinput="onPublishInput"
        maxlength="500"
        placeholder="这里支持存草稿或直接发布"
      ></textarea>
      <view class="composer-actions">
        <button class="composer-btn ghost" bindtap="saveDraft">存草稿</button>
        <button class="composer-btn solid" bindtap="publishNow">立即发布</button>
      </view>
      <button class="composer-close" bindtap="closePublish">取消</button>
    </view>
  </view>

  <view wx:if="{{commentsVisible}}" class="composer-mask">
    <view class="composer-panel comments-panel">
      <text class="composer-title">共鸣评论</text>
      <view wx:if="{{commentsEmpty}}" class="comment-empty">还没有评论，写下第一句吧。</view>
      <view wx:for="{{comments}}" wx:key="commentId" class="comment-row">
        <text class="comment-author">{{item.author.nickname}}</text>
        <text class="comment-content">{{item.content}}</text>
      </view>
      <textarea
        class="comment-input"
        value="{{commentInput}}"
        bindinput="onCommentInput"
        maxlength="300"
        placeholder="写一句真心话评论"
      ></textarea>
      <view class="composer-actions">
        <button class="composer-btn ghost" bindtap="closeComments">关闭</button>
        <button class="composer-btn solid" bindtap="submitComment">发送评论</button>
      </view>
    </view>
  </view>

  <!-- 底部固定毛玻璃导航 -->
  <view class="bottom-nav">
    <view class="nav-container">
      <view class="nav-glass"></view>
      <view class="nav-content">
        <view class="nav-item active">
          <image src="/assets/icons/wave.svg" class="nav-svg-icon active-icon" mode="aspectFit"></image>
          <text class="nav-text">冲浪</text>
        </view>
        <view class="nav-item" bindtap="goToHome">
          <image src="/assets/icons/cards_stack.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">真心话</text>
        </view>
        <view class="nav-item" bindtap="goToChat">
          <image src="/assets/icons/note.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">小纸条</text>
        </view>
      </view>
    </view>
  </view>
</view>
