<!-- pages/discovery/discovery.wxml -->
<view class="container" style="min-height: {{windowHeight}}px;">
  <view class="bg-gradient"></view>

  <!-- 顶部固定头部 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner" style="margin-top: {{headerInnerMT}}px; height: {{headerInnerH}}px;">
      <text class="logo-text">冲浪</text>
    </view>
    <!-- 三个子 Tab -->
    <view class="sub-tabs">
      <view
        class="sub-tab-item {{currentSubTab === 'hot' ? 'active' : ''}}"
        data-tab="hot"
        bindtap="switchSubTab">
        <text class="sub-tab-text">热议</text>
        <view class="sub-tab-indicator" wx:if="{{currentSubTab === 'hot'}}"></view>
      </view>
      <view
        class="sub-tab-item {{currentSubTab === 'cave' ? 'active' : ''}}"
        data-tab="cave"
        bindtap="switchSubTab">
        <text class="sub-tab-text">树洞</text>
        <view class="sub-tab-indicator" wx:if="{{currentSubTab === 'cave'}}"></view>
      </view>
      <view
        class="sub-tab-item {{currentSubTab === 'square' ? 'active' : ''}}"
        data-tab="square"
        bindtap="switchSubTab">
        <text class="sub-tab-text">广场</text>
        <view class="sub-tab-indicator" wx:if="{{currentSubTab === 'square'}}"></view>
      </view>
    </view>
  </view>

  <!-- 内容区 -->
  <scroll-view scroll-y="true" class="main-scroll" style="padding-top: calc({{statusBarHeight}}px + 168rpx);">

    <!-- ===== 热议 Tab ===== -->
    <view wx:if="{{currentSubTab === 'hot'}}">
      <view class="section-label">
        <text class="section-label-text">综合热度排行</text>
        <text class="section-label-sub">差异度 ×2 · 互动 ×2 · 转发 ×1</text>
      </view>

      <view wx:for="{{hotList}}" wx:key="id" class="hot-card {{item.rank <= 10 ? 'top10' : ''}}">
        <!-- 排名 + 火苗标签 -->
        <view class="hot-rank-row">
          <view class="hot-rank-badge {{item.rank <= 3 ? 'rank-top3' : ''}}">
            <text class="hot-rank-num">{{item.rank}}</text>
          </view>
          <view class="hot-fire-tag" wx:if="{{item.rank <= 10}}">
            <text class="hot-fire-icon">🔥</text>
            <text class="hot-fire-label">热议</text>
          </view>
          <view class="hot-gender-diff" wx:if="{{item.genderDiffHigh}}">
            <text class="hot-gender-text">男女分歧</text>
          </view>
        </view>

        <!-- 题目内容 -->
        <text class="hot-content">"{{item.content}}"</text>

        <!-- 数据条：双行多色进度条 -->
        <view class="hot-stats-row">
          <view class="hot-dual-progress">
            <!-- 选项 A -->
            <view class="hot-dual-row">
              <text class="hot-dual-label">选项 A</text>
              <view class="hot-dual-bar-bg">
                <view class="hot-dual-bar-fill agree-fill" style="width: {{item.agreePercent}}%;"></view>
              </view>
              <text class="hot-dual-pct">{{item.agreePercent}}%</text>
            </view>
            <!-- 选项 B -->
            <view class="hot-dual-row">
              <text class="hot-dual-label">选项 B</text>
              <view class="hot-dual-bar-bg">
                <view class="hot-dual-bar-fill disagree-fill" style="width: {{100 - item.agreePercent}}%;"></view>
              </view>
              <text class="hot-dual-pct">{{100 - item.agreePercent}}%</text>
            </view>
          </view>
        </view>

        <!-- 互动数据 -->
        <view class="hot-meta-row">
          <text class="hot-meta-item">💬 {{item.commentCount}}</text>
          <text class="hot-meta-item">↗ {{item.shareCount}}</text>
          <text class="hot-meta-item">综合热度 {{item.hotScore}}</text>
        </view>
      </view>
    </view>

    <!-- ===== 树洞 Tab ===== -->
    <view wx:if="{{currentSubTab === 'cave'}}">
      <view class="section-label">
        <text class="section-label-text">树洞</text>
        <text class="section-label-sub">默认匿名 · 真实表达 · 记入档案</text>
      </view>

      <view wx:for="{{caveList}}" wx:key="id" class="cave-card">
        <!-- 匿名用户信息 -->
        <view class="cave-user-row">
          <view class="cave-avatar-wrap">
            <text class="cave-avatar-emoji">{{item.virtualAvatar}}</text>
          </view>
          <view class="cave-user-info">
            <text class="cave-nickname">{{item.nickname}}</text>
            <text class="cave-time">{{item.timeAgo}}</text>
          </view>
          <view class="cave-anon-badge">
            <text class="cave-anon-text">匿名</text>
          </view>
        </view>

        <!-- 内容 -->
        <text class="cave-content">{{item.content}}</text>

        <!-- 互动区 -->
        <view class="cave-actions">
          <view class="cave-action-item" bindtap="likeCavePost" data-id="{{item.id}}">
            <text class="cave-action-icon">♡</text>
            <text class="cave-action-count">{{item.likeCount}}</text>
          </view>
          <view class="cave-action-item" bindtap="commentCavePost" data-id="{{item.id}}">
            <text class="cave-action-icon">○</text>
            <text class="cave-action-count">{{item.commentCount}} 回应</text>
          </view>
        </view>
      </view>

      <!-- 发布树洞入口 -->
      <view class="cave-publish-btn" bindtap="publishCavePost">
        <text class="cave-publish-text">+ 说点真心话</text>
      </view>
    </view>

    <!-- ===== 广场 Tab ===== -->
    <view wx:if="{{currentSubTab === 'square'}}">
      <view class="section-label">
        <text class="section-label-text">广场</text>
        <text class="section-label-sub">真实生活 · 感官体验 · 遇见有趣的人</text>
      </view>

      <!-- 分类筛选 -->
      <scroll-view scroll-x="true" class="square-filter-scroll" show-scrollbar="false">
        <view
          wx:for="{{squareFilters}}"
          wx:key="index"
          class="square-filter-chip {{currentSquareFilter === item ? 'active' : ''}}"
          data-filter="{{item}}"
          bindtap="switchSquareFilter">
          <text class="square-filter-text">{{item}}</text>
        </view>
      </scroll-view>

      <!-- 瀑布流内容 -->
      <view class="square-grid">
        <view wx:for="{{squareList}}" wx:key="id" class="square-item">
          <view class="square-img-wrap">
            <view class="square-img-placeholder" style="background: {{item.bgColor}};"></view>
            <view class="square-category-tag">
              <text class="square-category-text">{{item.category}}</text>
            </view>
          </view>
          <view class="square-item-footer">
            <view class="square-user-row">
              <text class="square-user-avatar-emoji">{{item.virtualAvatar}}</text>
              <text class="square-username">{{item.nickname}}</text>
            </view>
            <text class="square-caption">{{item.caption}}</text>
            <view class="square-item-meta">
              <text class="square-meta-like">♡ {{item.likeCount}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view style="height: 240rpx;"></view>
  </scroll-view>

  <!-- 发布按钮 -->
  <view class="fab" bindtap="openPublish">
    <text class="fab-icon">＋</text>
  </view>

  <!-- 底部固定毛玻璃导航 -->
  <view class="bottom-nav">
    <view class="nav-container">
      <view class="nav-glass"></view>
      <view class="nav-content">
        <view class="nav-item active">
          <image src="/assets/icons/wave.svg" class="nav-svg-icon active-icon" mode="aspectFit"></image>
          <text class="nav-text">冲浪</text>
        </view>
        <view class="nav-item" bindtap="goToHome">
          <image src="/assets/icons/cards_stack.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">真心话</text>
        </view>
        <view class="nav-item" bindtap="goToChat">
          <image src="/assets/icons/note.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">小纸条</text>
        </view>
      </view>
    </view>
  </view>
</view>
