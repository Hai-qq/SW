<!-- pages/discovery/discovery.wxml -->
<view class="container" style="min-height: {{windowHeight}}px; background: linear-gradient(180deg, #F5F3ED 0%, #E2E8E4 100%);">
  
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="icon-btn"><text style="font-size: 40rpx; font-weight: 300;">☰</text></view>
      <text class="logo-text">Same Wavelength</text>
      <image class="avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAxue1HnWTmY9jhMYkirM5bzPkGnNkeHG0Tk0XJF0yk5bF22dKPOBEwIrjYcOilieqt4WTL1683L0zErSr46zkUZNQOvn4m1tArSXRiUmG5ZPHtOwDpu8y8HABb22FcWnmeMrRBLXSjxA1Tcjv9EO8tN-IYr3DKO7BMTtAqmPdqXSxY_WXT8IZ2wXbLWi-UONpe5lanH5rggS57wrj7b9e2gEl7qOvUMzH6mlmCIwxFjXYFnvlth_I1kpC3xd_wpbKkH1COulhagGM"></image>
    </view>
  </view>

  <scroll-view scroll-y="true" class="main-scroll" style="padding-top: calc({{statusBarHeight}}px + 108rpx);">
    <view class="meta-date">
      <text>TUESDAY, APRIL 15</text>
      <text>AMSTERDAM</text>
    </view>

    <!-- Tabs -->
    <scroll-view scroll-x="true" class="tabs" show-scrollbar="false">
      <view
        wx:for="{{tabs}}"
        wx:key="*this"
        class="tab-item {{currentTab === item ? 'active' : ''}}"
        data-tab="{{item}}"
        bindtap="switchTab"
      >
        <text>{{item}}</text>
      </view>
    </scroll-view>

    <!-- Featured Thoughts Section -->
    <view class="section">
      <view class="section-title">
        <text class="title-text">Hot Waves (热门)</text>
        <text style="font-size: 32rpx; color: #8c8c8c;">⋯</text>
      </view>

      <view class="thought-card" wx:if="{{featuredItems.length}}">
        <view class="card-top">
          <text class="card-title">{{featuredItems[0].title || featuredItems[0].content}}</text>
          <text style="font-size: 32rpx; color: #8C8C8C;">⋯</text>
        </view>
        <view class="stats">
          <view class="progress-bar-bg">
            <view class="progress-bar-fill" style="width: 65%;"></view>
          </view>
          <view class="stats-text">
            <text class="black-text">{{featuredItems[0].category}} · {{featuredItems[0].author.nickname}}</text>
            <text>{{featuredItems[0].stats.likeCount}} 喜欢 · {{featuredItems[0].stats.commentCount}} 评论</text>
          </view>
        </view>
        <view class="avatars-group">
          <view class="stack">
            <image class="small-av" src="{{featuredItems[0].author.avatar}}"></image>
            <view class="small-av more-av">+{{featuredItems[0].stats.likeCount}}</view>
          </view>
          <text class="hint-msg">正在共鸣中...</text>
        </view>
        <view class="card-quote">
          <text>"{{featuredItems[0].content}}"</text>
        </view>
      </view>

    </view>

    <!-- Timeline Section -->
    <view class="section timeline-section">
      <view class="section-title">
        <text class="title-text">Surfing Feed</text>
        <view class="filter-btn">
          <text>最新冲浪</text>
          <text style="font-size: 32rpx; opacity: 0.6; padding-left: 8rpx; margin-top: -6rpx;">⌄</text>
        </view>
      </view>

      <view class="timeline">
        <view class="timeline-line"></view>
        
        <view class="timeline-item" wx:for="{{timelineItems}}" wx:key="feedId">
          <view class="timeline-dot {{index === 0 ? 'black-dot' : 'gray-dot'}}"></view>
          <text class="timeline-meta">{{item.author.nickname}} · {{item.category}}</text>
          <text class="timeline-content">{{item.content}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="fab" bindtap="openPublish">
    <text style="font-size: 48rpx; font-weight: 300;">＋</text>
  </view>

  <!-- 底部固定毛玻璃导航 -->
  <view class="bottom-nav">
    <view class="nav-container">
      <view class="nav-glass"></view>
      <view class="nav-content">
        <view class="nav-item active">
          <view class="nav-icon surf-icon">
            <view class="wave"></view>
          </view>
          <text class="nav-text">冲浪</text>
        </view>
        <view class="nav-item" bindtap="goToHome">
          <view class="nav-icon cards-icon">
            <view class="cards-tab"></view>
          </view>
          <text class="nav-text">真心话</text>
        </view>
        <view class="nav-item" bindtap="goToChat">
          <view class="nav-icon chat-icon">
            <view class="bubble"></view>
            <view class="tail"></view>
          </view>
          <text class="nav-text">小纸条</text>
        </view>
      </view>
    </view>
  </view>
</view>
