/* pages/profile/profile.wxss */
page { color: #1A1A1A; font-family: -apple-system, sans-serif; background: transparent; min-height: 100vh; }

.page-wrapper { position: relative; width: 100%; min-height: 100vh; overflow: hidden; }

.bg-gradient {
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  background: linear-gradient(180deg, #F8F1E4 0%, #EBE4D5 45%, #E1DAC7 100%);
  z-index: -1;
}

.container { width: 100%; }

/* Header */
.header {
  width: 100%;
  position: fixed;
  top: 0;
  z-index: 50;
  background: rgba(248,241,228,0.96);
  backdrop-filter: blur(10px);
  box-sizing: border-box;
  box-shadow: 0 20rpx 40rpx 12rpx rgba(248,241,228,0.95);
}
.header-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 40rpx 20rpx;
}
.back-btn, .setting-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(26,26,26,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon, .setting-icon { font-size: 30rpx; color: rgba(26,26,26,0.7); }
.header-title {
  font-size: 32rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  color: #1A1A1A;
}

.main-content {
  padding-top: 200rpx; /* fallback，实际由 JS 动态注入 inline style */
  padding-bottom: 300rpx;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

/* Profile Header */
.profile-header { display: flex; flex-direction: column; align-items: center; margin-bottom: 40rpx; }
.big-avatar-wrap { position: relative; width: 240rpx; height: 240rpx; margin-bottom: 24rpx; }
/* clip 层：保证 image 被精确裁剪为纯圆，border/shadow 都放这里 */
.big-avatar-clip {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  overflow: hidden;
  border: 6rpx solid #FFF;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.08);
  box-sizing: border-box;
}
.big-avatar { width: 100%; height: 100%; display: block; }
.avatar-ring {
  position: absolute;
  inset: -8rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(196,184,156,0.5);
}
.user-name { font-family: 'Noto Serif', serif; font-size: 52rpx; font-weight: bold; letter-spacing: -1rpx; margin-bottom: 16rpx; }
.badges { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.badge { padding: 10rpx 28rpx; border-radius: 40rpx; font-size: 20rpx; font-weight: bold; letter-spacing: 3rpx; }
.white-badge { background: #FFF; border: 1.5rpx solid rgba(0,0,0,0.06); color: #1A1A1A; }
.black-badge { background: #1A1A1A; color: #FFF; }
.user-desc { font-family: 'Noto Serif', serif; font-style: italic; font-size: 28rpx; color: rgba(0,0,0,0.55); line-height: 1.65; text-align: center; padding: 0 20rpx; }

/* Stats */
.stats-glass {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255,255,255,0.45);
  backdrop-filter: blur(10px);
  border: 1.5rpx solid rgba(255,255,255,0.5);
  border-radius: 36rpx;
  padding: 36rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.03);
}
.stat-item { display: flex; flex-direction: column; align-items: center; }
.stat-num { font-family: 'Noto Serif', serif; font-size: 40rpx; font-weight: bold; margin-bottom: 8rpx; }
.stat-label { font-size: 18rpx; font-weight: bold; color: rgba(0,0,0,0.4); letter-spacing: 2rpx; }
.stat-divider { width: 1.5rpx; height: 56rpx; background: rgba(0,0,0,0.06); }

/* Section */
.section { margin-bottom: 52rpx; }
.section-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28rpx; }
.sec-title { font-family: 'Noto Serif', serif; font-size: 40rpx; font-weight: bold; }
.sec-meta { font-size: 20rpx; font-weight: bold; color: rgba(0,0,0,0.4); letter-spacing: 2rpx; }

/* ===== 球状词云 ===== */
.word-cloud-container {
  position: relative;
  width: 100%;
  height: 560rpx;
  background: linear-gradient(145deg, #1A1A1A 0%, #2E2B24 100%);
  border-radius: 40rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  box-shadow: 0 24rpx 60rpx rgba(0,0,0,0.18);
}
.word-cloud-sphere {
  position: absolute;
  inset: 0;
}
.cloud-word {
  position: absolute;
  white-space: nowrap;
  font-weight: bold;
  line-height: 1;
  letter-spacing: 0.5rpx;
}
.word-cloud-overlay-label {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
}
.word-cloud-center-text {
  font-family: 'Noto Serif', serif;
  font-size: 80rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.08);
  line-height: 1;
}
.word-cloud-center-sub {
  font-family: 'Noto Serif', serif;
  font-size: 80rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.08);
  line-height: 1;
}

/* 词云图例 */
.cloud-legend {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.cloud-legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
}
.cloud-legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.cloud-legend-text {
  flex: 1;
  font-size: 26rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.75);
  letter-spacing: 1rpx;
}
.cloud-legend-score {
  font-size: 24rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.4);
  letter-spacing: 1rpx;
}

/* ===== 浏览记录 Tab ===== */
.browse-tab-row {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}
.browse-tab {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(196,184,156,0.18);
}
.browse-tab.active {
  background: #1A1A1A;
}
.browse-tab-text {
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: rgba(26,26,26,0.5);
}
.browse-tab.active .browse-tab-text { color: #FFFFFF; }

/* 抖音双列瀑布流 */
.douyin-grid {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
}
.douyin-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.douyin-card {
  position: relative;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.08);
}
.douyin-card-bg {
  position: absolute;
  inset: 0;
}
.douyin-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 30%, rgba(0,0,0,0.55) 100%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 20rpx;
}
.douyin-card-tag {
  background: rgba(255,255,255,0.2);
  border-radius: 999rpx;
  padding: 6rpx 16rpx;
  width: fit-content;
  margin-bottom: 10rpx;
}
.douyin-card-tag-text {
  font-size: 18rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.9);
  letter-spacing: 1rpx;
}
.douyin-card-content {
  font-size: 22rpx;
  line-height: 1.45;
  color: rgba(255,255,255,0.92);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 10rpx;
}
.douyin-card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.douyin-vote-label {
  font-size: 18rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.7);
  letter-spacing: 0.5rpx;
}
.douyin-agree {
  font-size: 18rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.55);
  letter-spacing: 0.5rpx;
}

/* 功能入口 */
.func-list {
  background: rgba(255,255,255,0.88);
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(196,184,156,0.12);
}
.func-item {
  display: flex;
  align-items: center;
  padding: 36rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.04);
  gap: 24rpx;
}
.func-item:last-child { border-bottom: none; }
.func-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: rgba(196,184,156,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.func-icon { font-size: 34rpx; }
.func-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1A1A;
  letter-spacing: 1rpx;
}
.func-arrow { font-size: 36rpx; color: rgba(26,26,26,0.3); }

/* Bottom Nav Shared */
.bottom-nav { position: fixed; bottom: 52rpx; left: 0; right: 0; display: flex; justify-content: center; z-index: 100; pointer-events: none; }
.nav-container { pointer-events: auto; position: relative; width: 58%; min-width: 520rpx; overflow: hidden; border-radius: 100rpx; box-shadow: 0 14rpx 28rpx rgba(196, 184, 156, 0.08); }
.nav-glass { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,247,243,0.92) 100%); border: 1px solid rgba(255,255,255,0.94); border-radius: 100rpx; box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.9); }
.nav-content { position: relative; z-index: 1; padding: 22rpx 42rpx 18rpx; display: flex; justify-content: space-between; align-items: center; }
.nav-item { display: flex; flex-direction: column; align-items: center; opacity: 1; min-width: 104rpx; }
.nav-svg-icon { width: 44rpx; height: 44rpx; margin-bottom: 10rpx; opacity: 0.5; }
.nav-item.active .nav-svg-icon,
.active-icon { opacity: 1; }
.nav-text { font-size: 20rpx; font-weight: bold; letter-spacing: 1rpx; color: rgba(24,24,24,0.55); }
.nav-item.active .nav-text { color: #1A1A1A; }

/* ====== 头像编辑 badge ====== */
.avatar-edit-badge {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: rgba(26,26,26,0.72);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #F8F1E4;
  z-index: 2;
}
.avatar-edit-icon {
  font-size: 22rpx;
  color: #FFF;
  line-height: 1;
}

/* ====== 新增：付费会员卡 ====== */
.member-card {
  background: linear-gradient(145deg, #1A1A1A 0%, #2C2A24 100%);
  border-radius: 36rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.14);
  border: 1rpx solid rgba(255,255,255,0.06);
}
.member-identity-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.member-badge {
  border-radius: 999rpx;
  padding: 10rpx 28rpx;
}
.member-badge-gold {
  background: linear-gradient(90deg, #D4AF37 0%, #F5D76E 100%);
}
.member-badge-plain {
  background: rgba(255,255,255,0.10);
  border: 1rpx solid rgba(255,255,255,0.15);
}
.member-badge-text {
  font-size: 22rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: #1A1A1A;
}
.member-badge-plain .member-badge-text { color: rgba(255,255,255,0.65); }
.member-sub-hint {
  font-size: 20rpx;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.5rpx;
}

/* 权益三列 */
.member-perks {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 40rpx;
}
.member-perk-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.member-perk-icon {
  font-size: 36rpx;
  line-height: 1;
  color: #F5D76E;
}
.member-perk-label {
  font-size: 22rpx;
  font-weight: bold;
  color: rgba(255,255,255,0.85);
  letter-spacing: 1rpx;
}
.member-perk-sub {
  font-size: 18rpx;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.5rpx;
}

/* 定价行 */
.member-purchase-area { display: flex; flex-direction: column; gap: 24rpx; }
.member-price-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  background: rgba(255,255,255,0.05);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
}
.member-price-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}
.member-price-label {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 1rpx;
}
.member-price-val {
  font-family: 'Noto Serif', serif;
  font-size: 32rpx;
  font-weight: bold;
  color: #F5D76E;
}
.member-price-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.08);
}
.member-open-btn {
  height: 88rpx;
  background: linear-gradient(90deg, #D4AF37 0%, #F5D76E 100%);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.member-open-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A1A1A;
  letter-spacing: 2rpx;
}

/* ====== 新增：编辑资料弹窗 ====== */
.edit-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  z-index: 200;
  backdrop-filter: blur(8px);
}
.edit-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  background: #F8F1E4;
  border-radius: 40rpx 40rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}
.edit-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 40rpx 24rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
}
.edit-panel-title {
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 1rpx;
  color: #1A1A1A;
}
.edit-panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(26,26,26,0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}
.edit-panel-close-icon { font-size: 30rpx; color: rgba(26,26,26,0.55); }

.edit-panel-scroll {
  flex: 1;
  overflow: hidden;
  padding: 0 40rpx;
}
.edit-field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  gap: 24rpx;
}
.edit-field-column {
  flex-direction: column;
  align-items: flex-start;
  gap: 16rpx;
}
.edit-field-label {
  font-size: 26rpx;
  font-weight: bold;
  color: rgba(26,26,26,0.55);
  letter-spacing: 1rpx;
  width: 96rpx;
  flex-shrink: 0;
}
.edit-input {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  background: transparent;
  border: none;
  height: 52rpx;
  padding: 0;
}
.edit-input-placeholder { color: rgba(26,26,26,0.3); font-size: 28rpx; }
.edit-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #1A1A1A;
  background: rgba(255,255,255,0.6);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  min-height: 120rpx;
  line-height: 1.6;
}
.edit-chip-row {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  flex-wrap: wrap;
  flex: 1;
}
.edit-chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(196,184,156,0.18);
  border: 1.5rpx solid transparent;
}
.edit-chip.active { background: #1A1A1A; }
.edit-chip-text { font-size: 24rpx; font-weight: bold; color: rgba(26,26,26,0.6); }
.edit-chip.active .edit-chip-text { color: #FFFFFF; }
.edit-avatar-preview-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.edit-avatar-preview {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(0,0,0,0.08);
}
.edit-avatar-hint {
  font-size: 22rpx;
  color: rgba(26,26,26,0.4);
  letter-spacing: 0.5rpx;
}

.edit-save-btn {
  margin: 20rpx 40rpx 40rpx;
  height: 96rpx;
  background: #1A1A1A;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.edit-save-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 3rpx;
}
