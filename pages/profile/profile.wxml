<!-- pages/profile/profile.wxml -->
<view class="page-wrapper" style="min-height: {{windowHeight}}px;">
<view class="bg-gradient"></view>
<scroll-view scroll-y="true" class="container" style="height: {{windowHeight}}px;">

  <!-- 顶部操作栏 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      <text class="header-title">我的档案</text>
      <view style="width: 72rpx;"></view>
    </view>
  </view>

  <view class="main-content" style="padding-top: {{mainContentPadPx}}px;">

    <!-- 个人信息头部 -->
    <view class="profile-header">
      <!-- 头像（右下角编辑 icon） -->
      <view class="big-avatar-wrap">
        <!-- clip 层：保证图片被裁剪成纯圆 -->
        <view class="big-avatar-clip">
          <image class="big-avatar" src="{{userInfo.avatar}}" mode="aspectFill"></image>
        </view>
        <view class="avatar-ring"></view>
        <view class="avatar-edit-badge" bindtap="openEditProfile">
          <text class="avatar-edit-icon">✎</text>
        </view>
      </view>

      <text class="user-name">{{userInfo.name}}</text>
      <view class="badges">
        <view class="badge white-badge"><text>{{userInfo.genderAge}}</text></view>
        <view class="badge black-badge"><text>{{userInfo.mbti}}</text></view>
      </view>
      <text class="user-desc">"{{userInfo.desc}}"</text>
    </view>

    <!-- 数据统计 -->
    <view class="stats-glass">
      <view class="stat-item">
        <text class="stat-num">1.2k</text>
        <text class="stat-label">访客</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">458</text>
        <text class="stat-label">粉丝</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">89</text>
        <text class="stat-label">关注</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">2.4k</text>
        <text class="stat-label">互动</text>
      </view>
    </view>

    <!-- 付费会员模块（stats 下方，词云上方） -->
    <view class="member-card">
      <!-- 会员身份 badge -->
      <view class="member-identity-row">
        <view class="member-badge {{isMember ? 'member-badge-gold' : 'member-badge-plain'}}">
          <text class="member-badge-text">{{isMember ? '✦ 三观库会员' : '普通用户'}}</text>
        </view>
        <text class="member-sub-hint" wx:if="{{!isMember}}">每日划卡 5 次上限</text>
      </view>

      <!-- 权益三列 -->
      <view class="member-perks">
        <view class="member-perk-item">
          <text class="member-perk-icon">∞</text>
          <text class="member-perk-label">无限划卡</text>
          <text class="member-perk-sub">{{isMember ? '已解锁' : '5次/天'}}</text>
        </view>
        <view class="member-perk-item">
          <text class="member-perk-icon">↯</text>
          <text class="member-perk-label">优先匹配</text>
          <text class="member-perk-sub">{{isMember ? '已解锁' : '会员专属'}}</text>
        </view>
        <view class="member-perk-item">
          <text class="member-perk-icon">≋</text>
          <text class="member-perk-label">深度报告</text>
          <text class="member-perk-sub">{{isMember ? '已解锁' : '会员专属'}}</text>
        </view>
      </view>

      <!-- 开通按钮 + 定价（非会员时显示） -->
      <view wx:if="{{!isMember}}" class="member-purchase-area">
        <view class="member-price-row">
          <view class="member-price-item">
            <text class="member-price-label">月卡</text>
            <text class="member-price-val">¥18</text>
          </view>
          <view class="member-price-divider"></view>
          <view class="member-price-item">
            <text class="member-price-label">季卡</text>
            <text class="member-price-val">¥48</text>
          </view>
          <view class="member-price-divider"></view>
          <view class="member-price-item">
            <text class="member-price-label">年卡</text>
            <text class="member-price-val">¥128</text>
          </view>
        </view>
        <view class="member-open-btn" bindtap="openMemberPurchase">
          <text class="member-open-text">立即开通 →</text>
        </view>
      </view>
    </view>

    <!-- 三观词云 -->
    <view class="section">
      <view class="section-top">
        <text class="sec-title">三观词云</text>
        <text class="sec-meta">{{answeredCount}} 题已回答</text>
      </view>

      <view class="word-cloud-container">
        <view class="word-cloud-sphere">
          <view
            wx:for="{{wordCloudItems}}"
            wx:key="id"
            class="cloud-word"
            style="font-size: {{item.size}}rpx; opacity: {{item.opacity}}; left: {{item.left}}%; top: {{item.top}}%; transform: rotate({{item.rotate}}deg); color: {{item.color}}; font-weight: {{item.weight}};">
            <text>{{item.word}}</text>
          </view>
        </view>
        <view class="word-cloud-overlay-label">
          <text class="word-cloud-center-text">三</text>
          <text class="word-cloud-center-sub">观</text>
        </view>
      </view>

      <view class="cloud-legend">
        <view class="cloud-legend-item" wx:for="{{topKeywords}}" wx:key="id">
          <view class="cloud-legend-dot" style="background: {{item.color}};"></view>
          <text class="cloud-legend-text">{{item.word}}</text>
          <text class="cloud-legend-score">{{item.strength}}%</text>
        </view>
      </view>
    </view>

    <!-- 浏览记录 -->
    <view class="section">
      <view class="section-top">
        <text class="sec-title">浏览记录</text>
        <view class="browse-tab-row">
          <view
            class="browse-tab {{currentBrowseTab === 'voted' ? 'active' : ''}}"
            data-tab="voted"
            bindtap="switchBrowseTab">
            <text class="browse-tab-text">我的投票</text>
          </view>
          <view
            class="browse-tab {{currentBrowseTab === 'history' ? 'active' : ''}}"
            data-tab="history"
            bindtap="switchBrowseTab">
            <text class="browse-tab-text">浏览过的</text>
          </view>
          <view
            class="browse-tab {{currentBrowseTab === 'published' ? 'active' : ''}}"
            data-tab="published"
            bindtap="switchBrowseTab">
            <text class="browse-tab-text">我的发布</text>
          </view>
        </view>
      </view>

      <view class="douyin-grid">
        <view class="douyin-col">
          <view
            wx:for="{{leftColItems}}"
            wx:key="id"
            class="douyin-card"
            style="height: {{item.height}}rpx;">
            <view class="douyin-card-bg" style="background: {{item.bgColor}};"></view>
            <view class="douyin-card-overlay">
              <view class="douyin-card-tag">
                <text class="douyin-card-tag-text">{{item.tag}}</text>
              </view>
              <text class="douyin-card-content">{{item.content}}</text>
              <view class="douyin-card-footer">
                <text class="douyin-vote-label">{{item.myVote}}</text>
                <text class="douyin-agree">{{item.agreePercent}}% 认同</text>
              </view>
            </view>
          </view>
        </view>
        <view class="douyin-col">
          <view
            wx:for="{{rightColItems}}"
            wx:key="id"
            class="douyin-card"
            style="height: {{item.height}}rpx;">
            <view class="douyin-card-bg" style="background: {{item.bgColor}};"></view>
            <view class="douyin-card-overlay">
              <view class="douyin-card-tag">
                <text class="douyin-card-tag-text">{{item.tag}}</text>
              </view>
              <text class="douyin-card-content">{{item.content}}</text>
              <view class="douyin-card-footer">
                <text class="douyin-vote-label">{{item.myVote}}</text>
                <text class="douyin-agree">{{item.agreePercent}}% 认同</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="section">
      <view class="func-list">
        <view class="func-item" bindtap="openPreferences">
          <view class="func-icon-wrap"><text class="func-icon">📝</text></view>
          <text class="func-label">偏好设定</text>
          <text class="func-arrow">›</text>
        </view>
        <view class="func-item" bindtap="openReport">
          <view class="func-icon-wrap"><text class="func-icon">📊</text></view>
          <text class="func-label">价值观报告</text>
          <text class="func-arrow">›</text>
        </view>
        <view class="func-item" bindtap="openSettings">
          <view class="func-icon-wrap"><text class="func-icon">⚙️</text></view>
          <text class="func-label">账号设置</text>
          <text class="func-arrow">›</text>
        </view>
      </view>
    </view>

  </view>

  <!-- 底部固定毛玻璃导航 -->
  <view class="bottom-nav">
    <view class="nav-container">
      <view class="nav-glass"></view>
      <view class="nav-content">
        <view class="nav-item" bindtap="goToDiscovery">
          <image src="/assets/icons/wave.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">冲浪</text>
        </view>
        <view class="nav-item" bindtap="goToHome">
          <image src="/assets/icons/cards_stack.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">真心话</text>
        </view>
        <view class="nav-item" bindtap="goToChat">
          <image src="/assets/icons/note.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">小纸条</text>
        </view>
      </view>
    </view>
  </view>

</scroll-view>

<!-- 编辑资料半屏弹窗 -->
<view class="edit-mask" wx:if="{{showEditPanel}}" catchtap="closeEditPanel"></view>
<view class="edit-panel" wx:if="{{showEditPanel}}">
  <view class="edit-panel-header">
    <text class="edit-panel-title">编辑资料</text>
    <view class="edit-panel-close" bindtap="closeEditPanel">
      <text class="edit-panel-close-icon">×</text>
    </view>
  </view>

  <scroll-view scroll-y="true" class="edit-panel-scroll">
    <!-- 头像 -->
    <view class="edit-field-row" bindtap="chooseAvatar">
      <text class="edit-field-label">头像</text>
      <view class="edit-avatar-preview-wrap">
        <image class="edit-avatar-preview" src="{{editForm.avatar}}" mode="aspectFill"></image>
        <text class="edit-avatar-hint">点击更换</text>
      </view>
    </view>

    <!-- 昵称 -->
    <view class="edit-field-row">
      <text class="edit-field-label">昵称</text>
      <input
        class="edit-input"
        value="{{editForm.name}}"
        placeholder="输入昵称"
        placeholder-class="edit-input-placeholder"
        bindinput="onEditName"
      />
    </view>

    <!-- 性别 -->
    <view class="edit-field-row">
      <text class="edit-field-label">性别</text>
      <view class="edit-chip-row">
        <view
          wx:for="{{genderOptions}}"
          wx:key="index"
          class="edit-chip {{editForm.gender === item ? 'active' : ''}}"
          data-value="{{item}}"
          bindtap="onEditGender">
          <text class="edit-chip-text">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 年龄 -->
    <view class="edit-field-row">
      <text class="edit-field-label">年龄</text>
      <input
        class="edit-input"
        value="{{editForm.age}}"
        placeholder="输入年龄"
        placeholder-class="edit-input-placeholder"
        type="number"
        bindinput="onEditAge"
      />
    </view>

    <!-- 城市 -->
    <view class="edit-field-row">
      <text class="edit-field-label">城市</text>
      <input
        class="edit-input"
        value="{{editForm.city}}"
        placeholder="输入所在城市"
        placeholder-class="edit-input-placeholder"
        bindinput="onEditCity"
      />
    </view>

    <!-- 个人签名 -->
    <view class="edit-field-row edit-field-column">
      <text class="edit-field-label">个人签名</text>
      <textarea
        class="edit-textarea"
        value="{{editForm.desc}}"
        placeholder="写点什么…"
        placeholder-class="edit-input-placeholder"
        bindinput="onEditDesc"
        maxlength="60"
        auto-height
      />
    </view>

    <view style="height: 40rpx;"></view>
  </scroll-view>

  <view class="edit-save-btn" bindtap="saveProfile">
    <text class="edit-save-text">保存</text>
  </view>
</view>

</view>
