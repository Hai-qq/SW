<!-- pages/profile/profile.wxml -->
<view class="page-wrapper" style="min-height: {{windowHeight}}px;">
<scroll-view scroll-y="true" class="container" style="height: {{windowHeight}}px; background: linear-gradient(180deg, #F5F3ED 0%, #E0E4E1 100%);">

  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="icon-btn" bindtap="goBack"><text style="font-size: 56rpx; font-weight: 300;">‹</text></view>
      <text class="logo-text">Same Wavelength</text>
      <view class="avatar-wrap-small">
        <image wx:if="{{profile.hasPrimaryPhoto}}" class="avatar-small" src="{{profile.primaryPhoto}}"></image>
      </view>
    </view>
  </view>

  <view class="main-content">
    
    <!-- Profile Header -->
    <view class="profile-header">
      <view class="big-avatar-wrap">
        <image wx:if="{{profile.hasPrimaryPhoto}}" class="big-avatar" src="{{profile.primaryPhoto}}"></image>
        <view class="avatar-ring"></view>
      </view>

      <text class="user-name">{{profile.nicknameText}}</text>
      <view class="badges">
        <view class="badge white-badge"><text>{{profile.genderAgeText}}</text></view>
        <view class="badge black-badge"><text>{{profile.mbtiText}}</text></view>
      </view>
      <text class="user-desc">"{{profile.signatureText}}"</text>
      <button class="edit-profile-btn" bindtap="goToEditProfile">编辑资料</button>
    </view>

    <!-- Stats -->
    <view class="stats-glass">
      <view class="stat-item"><text class="stat-num">{{profile.counts.visitors}}</text><text class="stat-label">访客</text></view>
      <view class="stat-divider"></view>
      <view class="stat-item"><text class="stat-num">{{profile.counts.followers}}</text><text class="stat-label">粉丝</text></view>
      <view class="stat-divider"></view>
      <view class="stat-item"><text class="stat-num">{{profile.counts.following}}</text><text class="stat-label">关注</text></view>
      <view class="stat-divider"></view>
      <view class="stat-item"><text class="stat-num">{{profile.counts.interactions}}</text><text class="stat-label">互动</text></view>
    </view>

    <!-- Documents -->
    <view class="docs-row">
      <view class="doc-card">
        <text style="font-size: 56rpx;">📝</text>
        <view>
          <text class="doc-title">My Preferences</text>
          <text class="doc-sub">偏好设定</text>
        </view>
      </view>
      <view class="doc-card">
        <text style="font-size: 56rpx;">📋</text>
        <view>
          <text class="doc-title">My Values Report</text>
          <text class="doc-sub">价值观报告</text>
        </view>
      </view>
    </view>

    <!-- Premium Banner -->
    <view class="premium-banner">
      <text class="premium-title">Unlocking high-resonance matches</text>
      <text class="premium-sub">开启高频率深度匹配，遇见对的人</text>
      <button class="premium-btn">立即升级</button>
      <text class="premium-bg-icon">✦</text>
    </view>

    <scroll-view scroll-x="true" class="price-cards" show-scrollbar="false">
      <view class="price-card">
        <text class="duration">1 个月</text>
        <text class="price">¥28</text>
        <text class="daily">¥0.93/天</text>
      </view>
      <view class="price-card hot">
        <view class="hot-tag">最热门</view>
        <text class="duration">3 个月</text>
        <text class="price">¥68</text>
        <text class="daily">¥0.75/天</text>
      </view>
      <view class="price-card">
        <text class="duration">12 个月</text>
        <text class="price">¥198</text>
        <text class="daily">¥0.54/天</text>
      </view>
    </scroll-view>

    <!-- Photo Wall -->
    <view class="section">
      <view class="section-top">
        <text class="sec-title">Photo Wall</text>
        <text class="sec-meta">{{profile.photoCountText}}</text>
      </view>
      <view class="photo-grid">
        <block wx:for="{{profile.visiblePhotos}}" wx:key="photoId">
          <image wx:if="{{item.hasPhoto}}" class="grid-img" src="{{item.photoUrl}}"></image>
          <view wx:if="{{!item.hasPhoto}}" class="grid-img photo-placeholder"></view>
        </block>
        <view class="add-photo-btn" bindtap="goToEditProfile"><text style="font-size: 60rpx; color: rgba(0,0,0,0.3);">+</text></view>
      </view>
    </view>

    <!-- History -->
    <view class="section history-section">
      <view class="section-top"><text class="sec-title">History</text></view>
      <view class="history-list">
        <view class="history-item">
          <view class="his-left"><text style="font-size: 32rpx; font-weight: 300; margin-right: 12rpx;">🕒</text><text class="his-text">浏览历史</text></view>
          <text style="font-size: 32rpx; color: #8C8C8C;">〉</text>
        </view>
        <view class="history-item" bindtap="goToConnections">
          <view class="his-left"><text style="font-size: 32rpx; font-weight: 300; margin-right: 12rpx;">∞</text><text class="his-text">我的连接</text></view>
          <text style="font-size: 32rpx; color: #8C8C8C;">〉</text>
        </view>
        <view class="history-item">
          <view class="his-left"><text style="font-size: 32rpx; font-weight: 300; margin-right: 12rpx;">☑</text><text class="his-text">我的投票</text></view>
          <text style="font-size: 32rpx; color: #8C8C8C;">〉</text>
        </view>
        <view class="history-item">
          <view class="his-left"><text style="font-size: 32rpx; font-weight: 300; margin-right: 12rpx;">✎</text><text class="his-text">我的发布</text></view>
          <text style="font-size: 32rpx; color: #8C8C8C;">〉</text>
        </view>
      </view>
    </view>
  </view>


</scroll-view>

</view>
