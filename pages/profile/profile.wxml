<!-- pages/profile/profile.wxml -->
<view class="page-wrapper" style="min-height: {{windowHeight}}px;">
<view class="bg-gradient"></view>
<scroll-view scroll-y="true" class="container" style="height: {{windowHeight}}px;">

  <!-- 顶部操作栏 -->
  <view class="header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-inner">
      <view class="back-btn" bindtap="goBack">
        <text class="back-icon">←</text>
      </view>
      <text class="header-title">我的档案</text>
      <view class="setting-btn">
        <text class="setting-icon">⚙</text>
      </view>
    </view>
  </view>

  <view class="main-content">

    <!-- 个人信息头部 -->
    <view class="profile-header">
      <view class="big-avatar-wrap">
        <image class="big-avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBt3naLQEnCWKVteeUGkKIuzOacHdDOhl8PJ7igG8HG7pVMRO-IF0FElwMYp8qwhGkIWQ8FurC1d_5V7Kh5hmXwtNl3_4C4ygR6uNysFWWXqCKgEIJOZm4d4KDhkrgHNImge1TIERx1_yakuYNKv3-OLyneSEXLzPqOE15pNSZWJ9x721kuzWtr93I26hQMKP4VcaIVKU5EKMVUZ1FZsX2OFWNUP4n5USY_LWNbUQ3yQCjvc82S0teyitLTKXgz3uoTJR4LJDg2Z-8" mode="aspectFill"></image>
        <view class="avatar-ring"></view>
      </view>
      <text class="user-name">林深处的麋鹿</text>
      <view class="badges">
        <view class="badge white-badge"><text>♀ 24</text></view>
        <view class="badge black-badge"><text>INFJ-T</text></view>
      </view>
      <text class="user-desc">"在喧嚣的世界寻找同频的声音，慢热却也深邃。"</text>
    </view>

    <!-- 数据统计 -->
    <view class="stats-glass">
      <view class="stat-item">
        <text class="stat-num">1.2k</text>
        <text class="stat-label">访客</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">458</text>
        <text class="stat-label">粉丝</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">89</text>
        <text class="stat-label">关注</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-num">2.4k</text>
        <text class="stat-label">互动</text>
      </view>
    </view>

    <!-- 4.2 球状关键词词云（三观档案） -->
    <view class="section">
      <view class="section-top">
        <text class="sec-title">三观词云</text>
        <text class="sec-meta">{{answeredCount}} 题已回答</text>
      </view>

      <view class="word-cloud-container">
        <view class="word-cloud-sphere">
          <!-- 词云关键词，大小/透明度/位置模拟球面分布 -->
          <view
            wx:for="{{wordCloudItems}}"
            wx:key="id"
            class="cloud-word"
            style="font-size: {{item.size}}rpx; opacity: {{item.opacity}}; left: {{item.left}}%; top: {{item.top}}%; transform: rotate({{item.rotate}}deg); color: {{item.color}}; font-weight: {{item.weight}};">
            <text>{{item.word}}</text>
          </view>
        </view>
        <view class="word-cloud-overlay-label">
          <text class="word-cloud-center-text">三</text>
          <text class="word-cloud-center-sub">观</text>
        </view>
      </view>

      <!-- 词云图例：主要倾向 -->
      <view class="cloud-legend">
        <view class="cloud-legend-item" wx:for="{{topKeywords}}" wx:key="id">
          <view class="cloud-legend-dot" style="background: {{item.color}};"></view>
          <text class="cloud-legend-text">{{item.word}}</text>
          <text class="cloud-legend-score">{{item.strength}}%</text>
        </view>
      </view>
    </view>

    <!-- 4.3 浏览记录：抖音风格瀑布流 -->
    <view class="section">
      <view class="section-top">
        <text class="sec-title">浏览记录</text>
        <view class="browse-tab-row">
          <view
            class="browse-tab {{currentBrowseTab === 'voted' ? 'active' : ''}}"
            data-tab="voted"
            bindtap="switchBrowseTab">
            <text class="browse-tab-text">我的投票</text>
          </view>
          <view
            class="browse-tab {{currentBrowseTab === 'history' ? 'active' : ''}}"
            data-tab="history"
            bindtap="switchBrowseTab">
            <text class="browse-tab-text">浏览过的</text>
          </view>
          <view
            class="browse-tab {{currentBrowseTab === 'published' ? 'active' : ''}}"
            data-tab="published"
            bindtap="switchBrowseTab">
            <text class="browse-tab-text">我的发布</text>
          </view>
        </view>
      </view>

      <!-- 瀑布流双列网格 -->
      <view class="douyin-grid">
        <view class="douyin-col">
          <view
            wx:for="{{leftColItems}}"
            wx:key="id"
            class="douyin-card"
            style="height: {{item.height}}rpx;">
            <view class="douyin-card-bg" style="background: {{item.bgColor}};"></view>
            <view class="douyin-card-overlay">
              <view class="douyin-card-tag">
                <text class="douyin-card-tag-text">{{item.tag}}</text>
              </view>
              <text class="douyin-card-content">{{item.content}}</text>
              <view class="douyin-card-footer">
                <text class="douyin-vote-label">{{item.myVote}}</text>
                <text class="douyin-agree">{{item.agreePercent}}% 认同</text>
              </view>
            </view>
          </view>
        </view>
        <view class="douyin-col">
          <view
            wx:for="{{rightColItems}}"
            wx:key="id"
            class="douyin-card"
            style="height: {{item.height}}rpx;">
            <view class="douyin-card-bg" style="background: {{item.bgColor}};"></view>
            <view class="douyin-card-overlay">
              <view class="douyin-card-tag">
                <text class="douyin-card-tag-text">{{item.tag}}</text>
              </view>
              <text class="douyin-card-content">{{item.content}}</text>
              <view class="douyin-card-footer">
                <text class="douyin-vote-label">{{item.myVote}}</text>
                <text class="douyin-agree">{{item.agreePercent}}% 认同</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="section">
      <view class="func-list">
        <view class="func-item" bindtap="openPreferences">
          <view class="func-icon-wrap"><text class="func-icon">📝</text></view>
          <text class="func-label">偏好设定</text>
          <text class="func-arrow">›</text>
        </view>
        <view class="func-item" bindtap="openReport">
          <view class="func-icon-wrap"><text class="func-icon">📊</text></view>
          <text class="func-label">价值观报告</text>
          <text class="func-arrow">›</text>
        </view>
        <view class="func-item" bindtap="openSettings">
          <view class="func-icon-wrap"><text class="func-icon">⚙️</text></view>
          <text class="func-label">账号设置</text>
          <text class="func-arrow">›</text>
        </view>
      </view>
    </view>

  </view>

  <!-- 底部固定毛玻璃导航 -->
  <view class="bottom-nav">
    <view class="nav-container">
      <view class="nav-glass"></view>
      <view class="nav-content">
        <view class="nav-item" bindtap="goToDiscovery">
          <image src="/assets/icons/wave.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">冲浪</text>
        </view>
        <view class="nav-item" bindtap="goToHome">
          <image src="/assets/icons/cards_stack.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">真心话</text>
        </view>
        <view class="nav-item" bindtap="goToChat">
          <image src="/assets/icons/note.svg" class="nav-svg-icon" mode="aspectFit"></image>
          <text class="nav-text">小纸条</text>
        </view>
      </view>
    </view>
  </view>

</scroll-view>
</view>
