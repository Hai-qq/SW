<!-- pages/settings/settings.wxml -->
<view class="settings-page" style="min-height: {{windowHeight}}px; padding-top: {{statusBarHeight}}px;">
  <view class="settings-header">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="settings-kicker">Same Wavelength</text>
    <text class="settings-title">设置</text>
  </view>

  <view class="settings-list">
    <view class="settings-row" bindtap="showComingSoon">
      <text>账号与安全</text>
      <text class="settings-arrow">→</text>
    </view>
    <view class="settings-row" bindtap="showComingSoon">
      <text>消息通知</text>
      <text class="settings-arrow">→</text>
    </view>
    <view class="settings-row" bindtap="showComingSoon">
      <text>隐私设置</text>
      <text class="settings-arrow">→</text>
    </view>
  </view>
</view>
