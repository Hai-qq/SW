/* pages/settings/settings.wxss */
page { color: #1A1A1A; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #F5F3ED; }

.settings-page { box-sizing: border-box; padding-left: 40rpx; padding-right: 40rpx; background: linear-gradient(180deg, #F5F3ED 0%, #E2E8E4 100%); }
.settings-header { padding-top: 36rpx; padding-bottom: 64rpx; }
.back-btn { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; margin-bottom: 32rpx; border-radius: 8rpx; background: rgba(255, 255, 255, 0.82); font-size: 56rpx; line-height: 72rpx; color: rgba(26, 26, 26, 0.72); }
.settings-kicker { display: block; margin-bottom: 24rpx; font-size: 20rpx; font-weight: bold; letter-spacing: 4rpx; color: rgba(26, 26, 26, 0.42); }
.settings-title { display: block; font-family: "Noto Serif", serif; font-size: 56rpx; font-style: italic; color: #1A1A1A; }
.settings-list { display: flex; flex-direction: column; gap: 18rpx; }
.settings-row { min-height: 96rpx; padding: 0 28rpx; border-radius: 8rpx; display: flex; align-items: center; justify-content: space-between; background: rgba(255, 255, 255, 0.82); box-sizing: border-box; font-size: 28rpx; font-weight: bold; color: rgba(26, 26, 26, 0.78); }
.settings-arrow { font-size: 32rpx; color: rgba(26, 26, 26, 0.42); }
