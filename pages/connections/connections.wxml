<view class="connections-page">
  <view class="connections-header">
    <text class="connections-title">我的连接</text>
    <text class="connections-subtitle">已经建立连接的人会在这里出现</text>
  </view>

  <view wx:if="{{showLoading}}" class="connections-empty">
    <text class="connections-empty-title">连接加载中</text>
  </view>

  <view wx:if="{{showEmpty}}" class="connections-empty">
    <text class="connections-empty-title">还没有连接</text>
    <text class="connections-empty-subtitle">回到首页继续滑卡，发现和你同频的人。</text>
  </view>

  <view wx:if="{{showList}}" class="connections-list">
    <view wx:for="{{items}}" wx:key="connectionId" class="connection-card" data-id="{{item.connectionId}}" bindtap="openChat">
      <image wx:if="{{item.hasAvatar}}" class="connection-avatar" src="{{item.targetUser.avatar}}"></image>
      <view wx:if="{{!item.hasAvatar}}" class="connection-avatar"></view>
      <view class="connection-body">
        <view class="connection-top">
          <text class="connection-name">{{item.targetUser.nickname}}</text>
          <text class="connection-status">{{item.statusText}}</text>
        </view>
        <text class="connection-subtitle">{{item.subtitleText}}</text>
      </view>
    </view>
  </view>
</view>
