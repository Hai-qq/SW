page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 245, 232, 0.9), transparent 34%),
    linear-gradient(180deg, #efe6d8 0%, #e8ddd0 40%, #ded7ca 100%);
  color: #1f1a17;
}

.page {
  min-height: 100vh;
}

.page-scroll {
  min-height: 100vh;
  padding: 32rpx 28rpx 56rpx;
  box-sizing: border-box;
}

.hero {
  padding: 32rpx 12rpx 28rpx;
}

.eyebrow {
  display: block;
  margin-bottom: 16rpx;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  color: rgba(31, 26, 23, 0.55);
  text-transform: uppercase;
}

.title {
  display: block;
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  line-height: 1.7;
  color: rgba(31, 26, 23, 0.66);
}

.card {
  margin-bottom: 28rpx;
  padding: 36rpx 28rpx;
  border-radius: 36rpx;
  background: rgba(255, 252, 248, 0.88);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  box-shadow: 0 18rpx 48rpx rgba(70, 50, 30, 0.08);
}

.card-title {
  display: block;
  margin-bottom: 28rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.field {
  margin-bottom: 24rpx;
}

.field:last-child {
  margin-bottom: 0;
}

.label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: rgba(31, 26, 23, 0.72);
}

.input,
.textarea,
.picker {
  width: 100%;
  box-sizing: border-box;
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: #fffdf9;
  border: 2rpx solid rgba(31, 26, 23, 0.08);
  font-size: 28rpx;
}

.textarea {
  min-height: 180rpx;
}

.picker {
  color: #1f1a17;
}

.add-photo-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.photo-input {
  flex: 1;
}

.photo-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-top: 2rpx solid rgba(31, 26, 23, 0.06);
}

.photo-thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  background: #f2ede4;
}

.photo-main {
  flex: 1;
}

.photo-url {
  display: block;
  font-size: 22rpx;
  line-height: 1.4;
  word-break: break-all;
}

.photo-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(31, 26, 23, 0.54);
}

.photo-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.primary-btn,
.secondary-btn,
.tiny-btn {
  border-radius: 999rpx;
  font-weight: 600;
}

.primary-btn {
  margin-top: 18rpx;
  background: #1f1a17;
  color: #fff9f0;
  height: 92rpx;
  line-height: 92rpx;
}

.secondary-btn {
  margin: 0;
  background: #fff4df;
  color: #1f1a17;
  border: 2rpx solid rgba(31, 26, 23, 0.08);
}

.add-btn {
  padding: 0 26rpx;
  height: 86rpx;
  line-height: 86rpx;
  font-size: 24rpx;
}

.tiny-btn {
  margin: 0;
  min-width: 104rpx;
  padding: 0 20rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 22rpx;
  background: #f7f2ea;
  color: #1f1a17;
}

.danger-btn {
  background: #2d211d;
  color: #fff4eb;
}
